local player = game.Players.LocalPlayer
local character = script.Parent
local humanoid = character:WaitForChild("Humanoid")
local rootPart = character:WaitForChild("HumanoidRootPart")

local fx = game.ReplicatedStorage.Assets.Effects

local Attributes = humanoid:WaitForChild("Attributes")
local WalkSpeedConfig = Attributes:WaitForChild("WalkSpeed")

local WALKSPEED = 20
local RUNSPEED = WALKSPEED * 1.25
local isSprinting = false

local function UpdateSpeedVariables()
	local Total = 0
	local slowPercentage = WalkSpeedConfig:GetAttribute("CombatSlow")
	local isSlowed = slowPercentage ~= nil 

	-- Sum up all standard attributes (Base + Armor + Etc)
	for Name, Value in pairs(WalkSpeedConfig:GetAttributes()) do
		if type(Value) == "number" and Name ~= "CombatSlow" then
			Total = Total + Value
		end
	end

	-- Apply percentage-based slow to the total sum
	if isSlowed and type(slowPercentage) == "number" then
		Total = Total * (1 - slowPercentage)
	end

	WALKSPEED = Total
	RUNSPEED = WALKSPEED * 1.25

	-- Force out of sprint if slowed
	if isSlowed and isSprinting then
		isSprinting = false
	end

	-- Re-apply speed correctly
	task.defer(function()
		if isSprinting then
			humanoid.WalkSpeed = RUNSPEED
		else
			humanoid.WalkSpeed = WALKSPEED
		end
	end)
end

WalkSpeedConfig.AttributeChanged:Connect(UpdateSpeedVariables)
UpdateSpeedVariables()

local lastRun = 0
local direction = 1
local lastPosition = rootPart.Position

local uis = game:GetService("UserInputService")
local ts = game:GetService("TweenService")
local rs = game:GetService("RunService")

local params = RaycastParams.new()
params.FilterType = Enum.RaycastFilterType.Include
params.FilterDescendantsInstances = {workspace:FindFirstChild("Map")}

uis.InputBegan:Connect(function(input, gpe)
	if gpe then return end
	if input.KeyCode == Enum.KeyCode.LeftControl then
		-- Prevent sprint if CombatSlow is active
		if WalkSpeedConfig:GetAttribute("CombatSlow") then return end

		isSprinting = not isSprinting -- Flips the boolean (true to false, false to true)

		if isSprinting then
			humanoid.WalkSpeed = RUNSPEED
			direction = 1
		else
			humanoid.WalkSpeed = WALKSPEED
		end
	end
end)

rs.Heartbeat:Connect(function()
	if (rootPart.Velocity * Vector3.new(1,0,1)).Magnitude > WALKSPEED * 1.1 and humanoid.FloorMaterial ~= Enum.Material.Air then
		if tick() - lastRun > 6/RUNSPEED then
			lastRun = tick()

			local step = fx.Dust:Clone()
			step.Parent = workspace.Fx
			step.CFrame = rootPart.CFrame * CFrame.new(direction, -3,0)
			local rayResult = workspace:Raycast(step.Position + Vector3.new(0,1,0), Vector3.new(0,-3,0), params)
			if rayResult then
				step.Attachment.Dust.Color = ColorSequence.new{
					ColorSequenceKeypoint.new(0, rayResult.Instance.Color),
					ColorSequenceKeypoint.new(1, rayResult.Instance.Color)
				}
			end

			step.Attachment.Dust:Emit(10)
			game.Debris:AddItem(step,1)
			direction = direction * -1
		end
		for i = 1, math.random(1,3) do
			local hb = Instance.new("Part", workspace.Fx)
			hb.Anchored = true
			hb.CanCollide = false
			hb.Transparency = .8
			hb.Name = "hb"
			hb.Material = Enum.Material.SmoothPlastic
			hb.CanQuery = false
			hb.Size = Vector3.new(.07,.07, math.random(4,6))
			local colorRand = math.random(1,3)
			if colorRand == 1 then
				hb.Color = Color3.fromRGB(86, 86, 86)
			else
				hb.Color = Color3.fromRGB(175, 175, 175)
			end
			local dirCFrame = CFrame.new(lastPosition, rootPart.Position)
			hb.CFrame = dirCFrame * CFrame.new(math.random(-25,25)/10,math.random(-3,3), math.random(-2,2))
			game.Debris:AddItem(hb,.2)
			ts:Create(hb,TweenInfo.new(.2), {Transparency = 1, Size = Vector3.new(0,0,0), CFrame = hb.CFrame * CFrame.new (0,0,math.random(2,4))}):Play()
		end
	else
		direction = 1
	end
	lastPosition = rootPart.Position
end)
