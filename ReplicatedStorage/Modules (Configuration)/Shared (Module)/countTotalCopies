--[[
	countTotalCopies

	Used to check how many copies of an item someone has
]]

--> Services
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local Players = game:GetService("Players")

--> Player
local PlayerData = ReplicatedStorage:WaitForChild("PlayerData")

--> Dependencies
local FormatNumber = require(ReplicatedStorage.Modules.Shared.FormatNumber)
local GameConfig = require(ReplicatedStorage.GameConfig)

--------------------------------------------------------------------------------

return function(Item, Player)

	-- If the item itself or its name is nil, the player can't have any copies.
	if not Item or not Item.Name then
		return 0
	end

	local Player = Player or Players.LocalPlayer
	local pData = PlayerData:WaitForChild(Player.UserId)
	if not pData then return 0 end

	local Count = 0

	-- Iterate only through the specific item category for efficiency
	local itemType = Item.Type

	if itemType and GameConfig.Categories[itemType] and pData.Items:FindFirstChild(itemType) then
		local InventoryItems = pData.Items[itemType]
		local Value = InventoryItems:FindFirstChild(Item.Name)

		if Value and Value:IsA("NumberValue") then
			Count = Value.Value
		else
			-- Count individual instances (like unique orbs, though we reverted that)
			-- This part might need adjustment depending on how non-stackable items are stored now
			for _, childValue in InventoryItems:GetChildren() do
				-- Check if the base name matches (e.g., "OrbName" from "OrbName#1")
				local baseName = childValue.Name:match("(.+)#%d+") or childValue.Name
				if baseName == Item.Name then
					Count += 1
				end
			end
		end
	end

	return Count
end
