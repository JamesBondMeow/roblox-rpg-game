-- Calls if there's no other activated callback
function ActivatedCallbacks:Default(Slot)
	local ExpectedKey = GetSlotKey(Slot.ItemInstance)
	local Item = nil

	-- Search the container for the exact matching tool (including enchantments)
	local function FindExactTool(Container)
		if not Container then return nil end
		for _, child in ipairs(Container:GetChildren()) do
			if child:IsA("Tool") and GetSlotKey(child) == ExpectedKey then
				return child
			end
		end
		return nil
	end

	-- Check if it is currently equipped
	Item = FindExactTool(Player.Character)
	local isEquipped = (Item ~= nil)

	-- If not equipped, find it in the backpack
	if not Item then
		Item = FindExactTool(Player.Backpack)
	end

	-- Fail-safe: Prevents the UI from silently breaking if the item is missing
	if not Item then return end 

	local Character = Player.Character
	local Humanoid = Character and Character:FindFirstChildOfClass("Humanoid")
	if not Humanoid then return end

	if isEquipped then
		Humanoid:UnequipTools()
	else
		Humanoid:EquipTool(Item)
	end
end

return ActivatedCallbacks
