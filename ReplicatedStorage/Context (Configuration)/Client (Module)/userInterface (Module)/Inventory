		local function OnUpdatedValue()
			local Equipped = Slot.Value ~= "" 
			local _Slot = (Equipped and Slots[Slot.Value]) or (LastEquipped and Slots[LastEquipped])
			if _Slot then
				if Equipped and isSlotInHotbar(_Slot) then _Slot:PushToInventory() end

				local baseName = string.split(_Slot.ItemInstance.Name, "|")[1]
				UpdateKeybinds(ContentLibrary.Orb[baseName], Equipped)
				UpdateSlotState(_Slot, Equipped)
				_Slot.Frame.Visible = not Equipped
			end
			LastEquipped = Slot.Value
		end
		Slot.Changed:Connect(OnUpdatedValue)
		OnUpdatedValue()
	end

