	ArmorLib
]]

--> Services
local CollectionService = game:GetService("CollectionService")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local ServerStorage = game:GetService("ServerStorage")
local Players = game:GetService("Players")

--> References
local PlayerData = ReplicatedStorage:WaitForChild("PlayerData")

--> Dependencies
local ContentLibrary = require(ReplicatedStorage.Modules.Shared.ContentLibrary)
local EventModule = require(ReplicatedStorage.Modules.Shared.Event)

local Morph = require(ServerStorage.Modules.Server.Morph)
local CreateValue = require(ServerStorage.Modules.Server.createValue)
local RemoveValue = require(ServerStorage.Modules.Server.removeValue)

local GameConfig = require(ReplicatedStorage.GameConfig)

--> Variables
local Library = script.Name

local ArmorLib = {}
local ChangeCd = {}

--------------------------------------------------------------------------------

local function ParseCompoundName(compoundName)
	local split = string.split(tostring(compoundName), "|")
	local baseName = split[1]
	local enchants = {}
	for i = 2, #split do table.insert(enchants, split[i]) end
	return baseName, enchants
end

local function RequestCallback(Model, Name, CallbackType, Parameters)
	EventModule:Fire("ServerToServerEquipmentCallback", Model, Name, CallbackType, Parameters)
	EventModule:FireAllClients("ServerToClientEquipmentCallback", Model, Name, CallbackType, Parameters)
end

local function GetActiveArmorObjects(Player)
	local pData = PlayerData:FindFirstChild(Player.UserId)
	if not pData then return {} end

	local ActiveArmor = pData:FindFirstChild("ActiveArmor")
	local Result = {}

	if ActiveArmor then
		for _, ValueObj in ActiveArmor:GetChildren() do
			if ValueObj.Value ~= "" then
				local baseName = ParseCompoundName(ValueObj.Value)
				Result[ValueObj.Name] = ContentLibrary.Armor[baseName]
			end
		end
	end
	return Result
end

function ArmorLib:Give(Player: Player, Armor, DontSave, ShopBought, Amount)
	local pData = PlayerData:WaitForChild(Player.UserId, 5)

	local isItem = typeof(Armor) == "table" 
	if not isItem then return end

	if pData then
		local Found = pData.Items[Library]:FindFirstChild(Armor.Name)
		local IsStackable = GameConfig.CanItemsStack or GameConfig.Categories[Library].IsStackable
		local CanGive = ((not Found) or IsStackable)
		local CanBuyMultiple = ShopBought == "Force" or (ShopBought and (not Armor.Config.Cost[4]) and IsStackable)
		if CanGive or CanBuyMultiple then
			CreateValue(pData, Armor, DontSave, Amount, Library)
			return true
		end
	end
end

function ArmorLib:Trash(Player: Player, Armor, Amount)
	local pData = PlayerData:WaitForChild(Player.UserId, 5)
	if pData then
		local armorBeingTrashedName = Armor.Name
		local ActiveArmor = pData:FindFirstChild("ActiveArmor")
		local SlotEquippedIn = nil

		for _, Slot in ActiveArmor:GetChildren() do
			if Slot.Value == armorBeingTrashedName then
				SlotEquippedIn = Slot.Name
				break
			end
		end

		RemoveValue(pData, Armor, Amount, Library)

		if SlotEquippedIn then
			ArmorLib:UnequipArmor(Player, armorBeingTrashedName, SlotEquippedIn)
			ActiveArmor[SlotEquippedIn].Value = ""
		end
	end
end

function ArmorLib:ClearStatistics(Statistics, SlotName)
	for _, Statistic in Statistics:GetChildren() do
		for Name, Value in Statistic:GetAttributes() do
			if string.find(Name, "Armor_" .. SlotName) then
				Statistic:SetAttribute(Name, nil)
			end
		end
	end
end

function ArmorLib:ClearBoosts(Boosts, SlotName)
	for _, Boost in GameConfig.ClassBoosts do
		local Value = Boosts[Boost]
		Value:SetAttribute("Armor_" .. SlotName, nil)
		Value:SetAttribute("ArmorAdditive_" .. SlotName, nil)
	end
end

function ArmorLib:EquipArmor(Player: Player, Armor, CompoundName: string?)
	CompoundName = CompoundName or Armor.Name
	local baseName, enchants = ParseCompoundName(CompoundName)

	local Character = Player.Character
	local Humanoid = Character and Character:FindFirstChild("Humanoid")
	local Attributes = Humanoid and Humanoid:WaitForChild("Attributes", 1)
	if not Attributes or Humanoid.Health <= 0 then return end

	local SlotName = Armor.Config.ArmorType or "Chestplate"
	local pData = PlayerData:WaitForChild(Player.UserId)
	local ActiveSlot = pData.ActiveArmor:FindFirstChild(SlotName)
	if ActiveSlot.Value ~= "" then
		ArmorLib:UnequipArmor(Player, ActiveSlot.Value, SlotName)
	end

	ActiveSlot.Value = CompoundName

	local Suffix = "_" .. SlotName

	local health = Armor.Config.Health or 0
	local walkSpeed = Armor.Config.WalkSpeed or 0
	local jumpPower = Armor.Config.JumpPower or 0

	-- Apply Enchantment Passive Stats
	local MaxHealthConfig = Attributes:FindFirstChild("Health")
	for _, enchantId in ipairs(enchants) do
		local eConfig = ContentLibrary.Material[enchantId]
		if not eConfig then
			for _, matData in pairs(ContentLibrary.Material) do
				if matData.Config and matData.Config.EnchantmentData and matData.Config.EnchantmentData.Id == enchantId then
					eConfig = matData
					break
				end
			end
		end

		if eConfig and eConfig.Config.EnchantmentData then
			local props = eConfig.Config.EnchantmentData.Properties or {}
			local family = eConfig.Config.EnchantmentData.Family or string.split(enchantId, "_")[1]

			if family == "Torrent" then
				walkSpeed = walkSpeed + (props.WalkSpeedBoost or 5)
				jumpPower = jumpPower - (props.JumpPowerDecrease or 5)
			elseif family == "Feather" then
				jumpPower = jumpPower + (props.JumpPowerBoost or 5)
				walkSpeed = walkSpeed - (props.WalkSpeedDecrease or 5)
			end
		end
	end

	Attributes.Health:SetAttribute("Armor" .. Suffix, health > 0 and health or nil)
	Attributes.WalkSpeed:SetAttribute("Armor" .. Suffix, walkSpeed ~= 0 and walkSpeed or nil)
	Attributes.JumpPower:SetAttribute("Armor" .. Suffix, jumpPower ~= 0 and jumpPower or nil)

	local Boosts = Humanoid:WaitForChild("Boosts")
	ArmorLib:ClearBoosts(Boosts, SlotName)

	if Armor.Config.Mana then
		local ManaAttributes = Humanoid:WaitForChild("Mana")
		ManaAttributes.MaxMana:SetAttribute("Armor" .. Suffix, Armor.Config.Mana)
	end

	if Armor.Config.DamageClass then
		local DamageClass = Armor.Config.DamageClass
		local DamagePoints = Armor.Config.DamagePoints[1]
		local Additive = Armor.Config.DamagePoints[2]

		Boosts[DamageClass]:SetAttribute((Additive and ("ArmorAdditive" .. Suffix)) or ("Armor" .. Suffix), DamagePoints)
	end

	local Statistics = Humanoid.Statistics
	ArmorLib:ClearStatistics(Statistics, SlotName)

	for _, Attribute in Statistics:GetChildren() do
		local Value = Armor.Config[Attribute.Name]
		if not Value then continue end
		local IsAdditive = Value[2]
		Attribute:SetAttribute((IsAdditive and ("ArmorAdditive" .. Suffix)) or ("Armor" .. Suffix), Value[1])
	end

	Morph:ApplyOutfit(Player, Armor, GetActiveArmorObjects(Player))
	RequestCallback(Armor.Instance, Armor.Name, "OnEquipped", {Player, Armor.Config})
end

function ArmorLib:UnequipArmor(Player: Player, ArmorName: string, SlotName: string)
	local Character = Player.Character
	local Humanoid = Character and Character:FindFirstChild("Humanoid")
	local pData = PlayerData:WaitForChild(Player.UserId)

	if not SlotName then
		for _, Slot in pData.ActiveArmor:GetChildren() do
			if Slot.Value == ArmorName then
				SlotName = Slot.Name
				break
			end
		end
	end
	if not SlotName then return end 

	local baseName = ParseCompoundName(ArmorName)
	local Armor = ContentLibrary[Library][baseName]
	if Armor then
		RequestCallback(Armor.Instance, Armor.Name, "OnUnequipped", {Player, Armor.Config})
	end

	local Suffix = "_" .. SlotName

	local Attributes = Humanoid and Humanoid:FindFirstChild("Attributes")
	if Attributes then
		Attributes.Health:SetAttribute("Armor"..Suffix, nil)
		Attributes.WalkSpeed:SetAttribute("Armor"..Suffix, nil)
		Attributes.JumpPower:SetAttribute("Armor"..Suffix, nil)
	end

	local Boosts = Humanoid and Humanoid:FindFirstChild("Boosts")
	if Boosts then ArmorLib:ClearBoosts(Boosts, SlotName) end

	local ManaAttributes = Humanoid and Humanoid:FindFirstChild("Mana")
	if ManaAttributes then ManaAttributes.MaxMana:SetAttribute("Armor"..Suffix, nil) end

	local Statistics = Humanoid and Humanoid:FindFirstChild("Statistics")
	if Statistics then ArmorLib:ClearStatistics(Statistics, SlotName) end

	pData.ActiveArmor[SlotName].Value = ""
	Morph:ClearOutfit(Player, SlotName, GetActiveArmorObjects(Player))
end

