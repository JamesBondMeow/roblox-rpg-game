	-- EQUIPMENT LOGIC

	local function UpdateEquipmentSlot(SlotName, ItemName, CategoryName, UnequipCallback)
		local SlotFrame = EquipmentSlots[SlotName]

		-- Destroy old maid and create a fresh one to clear connections
		if EquipmentMaids[SlotName] then
			EquipmentMaids[SlotName]:Destroy()
		end
		local SlotMaid = Maid.new()
		EquipmentMaids[SlotName] = SlotMaid

		local Canvas = SlotFrame:WaitForChild("ItemIconCanvas")
		local Icon = Canvas:WaitForChild("ItemIcon")
		local Button = SlotFrame:WaitForChild("SlotButton")

		if ItemName and ItemName ~= "" then
			-- Safely parse the compound string so we can fetch the image and setup the tooltip
			local split = string.split(ItemName, "|")
			local baseName = split[1]
			local enchants = {}
			for i = 2, #split do table.insert(enchants, split[i]) end

			local ItemData = ContentLibrary[CategoryName][baseName]
			if ItemData then
				Icon.Visible = true
				-- Ensure item icon is fully opaque when equipped
				Icon.ImageTransparency = 0 

				if ItemData.Config.IconId then
					Icon.Image = tonumber(ItemData.Config.IconId) and `rbxassetid://{ItemData.Config.IconId}` or ItemData.Config.IconId
				else
					Icon.Image = "" -- Fallback
				end

				-- Tooltip
				local MainColor = ColorModule:GetPrimaryColor(ItemData)
				local Primary, Secondary, _ = ColorModule:ConvertToHSV3(MainColor)

				-- Forge a mock instance and stamp the enchantments so the tooltip reads them properly
				local MockInstance = ItemData.Instance:Clone()
				if #enchants > 0 then
					MockInstance:SetAttribute("Enchantments", table.concat(enchants, ","))
				end

				local TooltipConnections = SetTooltipListener(SlotFrame, MockInstance, Primary, Secondary)

				for _, Conn in TooltipConnections do
					SlotMaid:Add(Conn)
				end

				-- Unequip Action
				SlotMaid:Add(Button.Activated:Connect(function()
					if UnequipCallback then UnequipCallback() end
				end))
			end
		else
			-- Slot Empty: Apply Placeholders
			Icon.Visible = true
			Icon.ImageTransparency = 0.9

			if CategoryName == "Armor" then
				Icon.Image = "rbxassetid://138796651411619"
			elseif CategoryName == "Accessory" then
				Icon.Image = "rbxassetid://125639651186784"
			elseif CategoryName == "Orb" then
				Icon.Image = "rbxassetid://122817610344022"
			else
				Icon.Image = ""
			end
		end
	end

	-- Helper to check if an item is currently equipped anywhere
	local function IsItemEquipped(ItemName)
		local ActiveArmor = pData:WaitForChild("ActiveArmor")
		if ActiveArmor.Helmet.Value == ItemName then return true end
		if ActiveArmor.Pauldron.Value == ItemName then return true end
		if ActiveArmor.Chestplate.Value == ItemName then return true end

		local EquippedSlots = pData:WaitForChild("EquippedSlots")
		for _, Slot in EquippedSlots:GetChildren() do
			if Slot.Value == ItemName then return true end
		end

		local EquippedOrbs = pData:WaitForChild("EquippedOrbs")
		for _, Slot in EquippedOrbs:GetChildren() do
			if Slot.Value == ItemName then return true end
		end

		return false
	end

	-- Updates visibility of inventory slots based on equipment status
	local function UpdateInventorySlotVisibility()
		for slotKey, Slot in pairs(Slots) do
			if Slot.ItemType == "Armor" or Slot.ItemType == "Accessory" or Slot.ItemType == "Orb" then
				-- Strictly use the dictionary slotKey to verify if it's equipped
				if IsItemEquipped(slotKey) then
					if not isSlotInHotbar(Slot) then
						Slot.Frame.Visible = false
					end
				else
					Slot.Frame.Visible = true
				end
			end
		end
	end

	local function RefreshEquipmentUI()
		-- 1. Armor Slots
		local ActiveArmor = pData:WaitForChild("ActiveArmor")

		UpdateEquipmentSlot("Helmet", ActiveArmor.Helmet.Value, "Armor", function()
			EventModule:InvokeServer("UnequipArmor", ActiveArmor.Helmet.Value)
		end)

		UpdateEquipmentSlot("Pauldron", ActiveArmor.Pauldron.Value, "Armor", function()
			EventModule:InvokeServer("UnequipArmor", ActiveArmor.Pauldron.Value)
		end)

		UpdateEquipmentSlot("Chestplate", ActiveArmor.Chestplate.Value, "Armor", function()
			EventModule:InvokeServer("UnequipArmor", ActiveArmor.Chestplate.Value)
		end)

		-- 2. Accessory Slots
		local EquippedSlotsData = pData:WaitForChild("EquippedSlots")

		UpdateEquipmentSlot("Accessory1", EquippedSlotsData["1"].Value, "Accessory", function()
			EventModule:InvokeServer("UnequipAccessory", 1) 
		end)

		UpdateEquipmentSlot("Accessory2", EquippedSlotsData["2"].Value, "Accessory", function()
			EventModule:InvokeServer("UnequipAccessory", 2)
		end)

		-- 3. Orb Slots
		local EquippedOrbsData = pData:WaitForChild("EquippedOrbs")

		UpdateEquipmentSlot("Orb1", EquippedOrbsData["1"].Value, "Orb", function()
			EventModule:InvokeServer("UnequipOrb", 1)
		end)

		UpdateEquipmentSlot("Orb2", EquippedOrbsData["2"].Value, "Orb", function()
			EventModule:InvokeServer("UnequipOrb", 2)
		end)

		UpdateEquipmentSlot("Orb3", EquippedOrbsData["3"].Value, "Orb", function()
			EventModule:InvokeServer("UnequipOrb", 3)
		end)

		UpdateInventorySlotVisibility()
	end

