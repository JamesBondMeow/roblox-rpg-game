--[[
	PlayerHUD
	Handles the overhead display for players, including names, levels, ranks, and special tags.
]]

--> Services
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local Players = game:GetService("Players")
local MarketplaceService = game:GetService("MarketplaceService")

--> References
local PlayerData = ReplicatedStorage:WaitForChild("PlayerData")
local GradientFolder = ReplicatedStorage:WaitForChild("Assets"):WaitForChild("Gradients")

--> Dependencies
local Tween = require(ReplicatedStorage.Modules.Shared.Tween)
local FormatNumber = require(ReplicatedStorage.Modules.Shared.FormatNumber)
local Titles = require(ReplicatedStorage.Modules.Shared.Titles)
local ProductLib = require(ReplicatedStorage.Modules.Shared.Product)
local GameConfig = require(ReplicatedStorage.GameConfig)

--------------------------------------------------------------------------------

if not GameConfig.EnabledFeatures.PlayerHUD then
	return {}
end

--// Title & Tag Logic
--------------------------------------------------------------------------------

-- Finds the highest rank a player has earned based on their level.
local function getRankForLevel(level)
	for _, rankData in ipairs(Titles.Ranks) do
		if level >= rankData.Level then
			return rankData -- Return the entire rank data table
		end
	end
	return nil
end

-- Determines the highest priority tag a player should have.
local function getBestTag(player)
	local bestTag = nil
	local highestWeight = -1

	-- 1. Check ID-based tags (Owner, Tester)
	for tagName, userIds in pairs(Titles.SpecialUserIDs) do
		if table.find(userIds, player.UserId) then
			local tagData = Titles.Tags[tagName]
			if tagData and tagData.Weight > highestWeight then
				bestTag = tagData
				highestWeight = tagData.Weight
			end
		end
	end

	-- 2. Check Gamepass-based tags (VIP, MVP)
	local ownedProducts = ProductLib:GetProducts(player)
	for _, productData in ipairs(ownedProducts) do
		if productData.Tag then
			local tagData = Titles.Tags[productData.Tag]
			if tagData and tagData.Weight > highestWeight then
				bestTag = tagData
				highestWeight = tagData.Weight
			end
		end
	end

	return bestTag
end

-- Helper function to apply either a Color or a Gradient to a TextLabel
local function applyAppearance(textLabel, data)
	for _, child in ipairs(textLabel:GetChildren()) do
		if child:IsA("UIGradient") then
			child:Destroy()
		end
	end

	if data.Gradient then
		local gradient = GradientFolder:FindFirstChild(data.Gradient)
		if gradient then
			gradient:Clone().Parent = textLabel
			textLabel.TextColor3 = Color3.new(1, 1, 1)
		else
			warn("Gradient '" .. data.Gradient .. "' not found in Assets/Gradients.")
			textLabel.TextColor3 = Color3.new(1, 0, 1)
		end
	elseif data.Color and not data.Gradient then
		textLabel.TextColor3 = data.Color
	end
end


--// HUD Creation & Management
--------------------------------------------------------------------------------

local function SetupOverheadGui(Player, Character: Model): BillboardGui
	-- 1. Wait for Data (Timeout allowed because Data should replicate globally)
	local pData = PlayerData:WaitForChild(tostring(Player.UserId), 30)
	if not pData then
		warn("PlayerHUD: Could not find PlayerData for " .. Player.Name)
		return nil
	end

	local Stats = pData:WaitForChild("Stats", 10)
	local Level = Stats and Stats:WaitForChild("Level", 10)

	if not Level then
		warn("PlayerHUD: Could not find Level data for " .. Player.Name)
		return nil
	end

	-- 2. Wait for Root Part (Infinite Wait allowed for StreamingEnabled)
	-- If we time out here, the GUI never appears if the player is far away.
	-- By waiting indefinitely, the GUI appears exactly when they stream in.
	local Root = Character:WaitForChild("HumanoidRootPart")

	-- Check if character is still alive after waiting
	if not Character.Parent then return nil end

	local Gui = script:WaitForChild("BillboardGui"):Clone()

	local tagLabel = Gui.Tag
	local titleLabel = Gui.Title

	local function updateNameplate()
		-- Safety check inside update function
		if not Player or not Player.Parent then return end

		local bestTagData = getBestTag(Player)
		local rankData = getRankForLevel(Level.Value) 

		if bestTagData then
			tagLabel.Text = `<b>{bestTagData.Text}</b>`
			applyAppearance(tagLabel, bestTagData)
			tagLabel.Visible = true
		else
			tagLabel.Visible = false
		end

		if rankData then
			titleLabel.Text = `<b>{rankData.Title}</b>`
			applyAppearance(titleLabel, rankData)
			titleLabel.Visible = true
		else
			titleLabel.Visible = false
		end

		local playerNameString = Player.DisplayName ~= Player.Name and `<b>{Player.DisplayName} ({Player.Name})</b>` or `<b>{Player.DisplayName}</b>`
		playerNameString ..= ` <font size='10' color="rgb(255,255,255)">[{FormatNumber(Level.Value, "Suffix")}]</font>`
		Gui.DisplayName.Text = playerNameString
	end

	Level.Changed:Connect(updateNameplate)

	-- Listen for attribute changes on ALL players to update tags dynamically
	local attrConnection = Player.AttributeChanged:Connect(function(attrName)
		updateNameplate()
	end)

	Gui.Destroying:Connect(function()
		if attrConnection then attrConnection:Disconnect() end
	end)

	-- Initial setup
	updateNameplate()

	Gui.Adornee = Root
	Gui.Enabled = true
	Gui.StudsOffsetWorldSpace = Vector3.new(0, Root.Size.Y * 1.5, 0)
	Gui.Parent = Character

	return Gui
end

local function CharacterAdded(Character)
	local Player = Players:GetPlayerFromCharacter(Character)
	if not Player then return end 

	local Humanoid = Character:WaitForChild("Humanoid") :: Humanoid
	Humanoid.DisplayDistanceType = Enum.HumanoidDisplayDistanceType.None

	local Gui = SetupOverheadGui(Player, Character)
end

local function PlayerAdded(Player)
	if Player.Character then
		task.spawn(CharacterAdded, Player.Character)
	end
	Player.CharacterAdded:Connect(CharacterAdded)
end

for _, Player in Players:GetPlayers() do
	task.spawn(PlayerAdded, Player)
end

Players.PlayerAdded:Connect(PlayerAdded)

return {}
