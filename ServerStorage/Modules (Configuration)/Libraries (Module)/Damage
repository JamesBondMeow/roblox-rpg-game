local function InteractParry(Player, Mob, Damage)
	local Character = Player.Character
	local DidNotInteract = true

	local Tool = Character:FindFirstChildWhichIsA("Tool")
	local ItemConfig = Tool and Tool:FindFirstChild("ItemConfig") and require(Tool.ItemConfig)

	if ItemConfig and ItemConfig.BlockAndParry then
		local IsReleased = AttributeModule:GetAttribute(Tool, "Released")

		local MobPivot = Mob and Mob.Instance:GetPivot().Position
		local CharacterPivot = Character:GetPivot().Position
		local IsBlocking = AttributeModule:GetAttribute(Tool, "Blocking")

		if IsReleased then
			Damage = 0

			if Mob then
				local KnockbackValue = ItemConfig.Knockback or ItemConfig.BlockAndParry.Knockback
				if KnockbackValue then
					Knockback:Activate(Mob.Instance:FindFirstChild("Torso"), KnockbackValue, CharacterPivot, MobPivot)
				end

				local ParryToMob = ItemConfig.BlockAndParry.ParryToMob
				if ParryToMob then
					EventModule:FireAllClients("ForceAnimateMob", Mob.Instance, ParryToMob[math.random(#ParryToMob)])
				end

				local StunTime = ItemConfig.BlockAndParry.StunTime
				if StunTime then
					-- Fencer Stun Bonus
					local fencerProps = GetToolEnchantmentProps(Tool, "Fencer")
					if fencerProps then
						StunTime += (fencerProps.BonusStun or 1)
					end
					RequestStunMob(Mob, StunTime)
				end

				DamageLib:DamageMob(Player, Mob, {ClassType = "Melee", Ignore = true, Tool = Tool, Multiplier = ItemConfig.BlockAndParry.Multiplier or true})
				ShareDamageCallback(Player, Tool.Name, "OnParried", {Tool, Mob.Instance})
			end
		elseif not Mob or IsBlocking then
			-- Normal block damage reduction
			Damage = math.clamp(Damage - (Damage * ItemConfig.BlockAndParry.Absorption), 0, Damage)
		end

		if not Mob or not Mob.Ranged then
			if IsReleased then
				AttributeModule:SetAttribute(Tool, "BlockResult", "Parried|" .. os.clock())
				AttributeModule:SetAttribute(Tool, "Blocking", nil)
			elseif IsBlocking then
				AttributeModule:SetAttribute(Tool, "BlockResult", "Blocked|" .. os.clock())
			end

			AttributeModule:SetAttribute(Tool, "Released", nil)
		end

		DidNotInteract = not IsReleased and not IsBlocking
	end

	return Damage, DidNotInteract
end

function DamageLib.Hurt(Player: Player, Damage: number, Mob)
	if typeof(Mob) == "Instance" then
		Mob = Mobs[Mob]
	end

	if Mob and AttributeModule:GetAttribute(Mob.Instance, "Stunned") then
		return
	end

	local Character = Player.Character
	local Humanoid = Character and Character:FindFirstChildWhichIsA("Humanoid") :: Humanoid
	if not Character then return end

	local pData = ReplicatedStorage:WaitForChild("PlayerData"):WaitForChild(Player.UserId)

	local Attributes = pData.Attributes
	local Constitution = Attributes.Constitution
	if Constitution.Value > 0 then
		local HitOpportunity = math.clamp(Constitution.Value * GameConfig.Attributes.Constitution.Amplifier, 0, math.max(MOB_MISS_MAX_CHANCE - (Mob and Mob.Config.WeightToMissChance or 0), 0))
		if math.random(100) < HitOpportunity then 
			EventModule:FireClient("PlayerDamagedEntity", Player, nil, "Missed!", GameConfig.MissColor, GameConfig.MissSFX)
			return false
		end
	end

	local RawDefense = 0
	local Statistics = Humanoid:FindFirstChild("Statistics")
	for Name, Value in (Statistics and Statistics.Defense:GetAttributes() or {}) do
		local IsAdditive = string.find(Name, "Additive")
		if IsAdditive then
			RawDefense += Value
		elseif not IsAdditive then
			RawDefense += Value * Damage
		end
	end

	Damage = math.clamp(math.round(Damage - RawDefense), 1, math.huge)
	
	-- Aegis (Negate Attack)
	local aegisProps, aegisStacks, aegisOmni = GetArmorEnchantmentProps(Player, "Aegis")
	if aegisStacks > 0 then
		local chance = aegisProps.Chance or 0.05
		local finalChance = (chance * aegisStacks) + (chance * 1.5 * aegisOmni)

		if Random:NextNumber() <= finalChance then
			CreateFloatingText("✦ Aegis", Color3.fromRGB(200, 200, 255), Character.PrimaryPart)
			return false -- Negated
		end
	end
	
	-- Gambler Curse Modifier (Takes +20% damage per piece)
	local gamblerProps, gamblerStacks = GetArmorEnchantmentProps(Player, "Gambler")
	if gamblerStacks > 0 then
		Damage = Damage * (1 + (0.2 * gamblerStacks)) 
	end

	local Humanoid = Character:FindFirstChild("Humanoid")
	if not Humanoid or Character:FindFirstChildWhichIsA("ForceField") or not Character:FindFirstChild("Torso") or Character.Torso:FindFirstChildWhichIsA("ForceField") then
		return false
	end

	local NewDamage, DidNotInteract = InteractParry(Player, Mob, Damage)
	Damage = NewDamage

	Damage = math.round(Damage)
	local CanDamage = Damage > 0
	if CanDamage then
		Humanoid.Health = math.clamp(Humanoid.Health - Damage, 0, Humanoid.MaxHealth)
		
		-- Only apply knockback to the player if they were NOT blocking (DidNotInteract)
		if Mob and Mob.Instance and DidNotInteract then
			local charTorso = Character:FindFirstChild("Torso") or Character:FindFirstChild("UpperTorso") or Character:FindFirstChild("HumanoidRootPart")
			if charTorso then
				Knockback:Activate(charTorso, 7.5, Mob.Instance:GetPivot().Position, Character:GetPivot().Position)
			end
		end

		-- Slow the player down and force them out of sprint
		local walkSpeedConfig = Humanoid:FindFirstChild("Attributes") and Humanoid.Attributes:FindFirstChild("WalkSpeed")
		if walkSpeedConfig then
			walkSpeedConfig:SetAttribute("CombatSlow", 0.5)
			task.delay(3, function()
				if walkSpeedConfig then
					walkSpeedConfig:SetAttribute("CombatSlow", nil)
				end
			end)
		end

		-- Force the character's sprint value to false
		local runningVal = Character:FindFirstChild("Running")
		if runningVal and runningVal:IsA("BoolValue") then
			runningVal.Value = false
		end

		-- Thorns
		local thornsProps, thornsStacks = GetArmorEnchantmentProps(Player, "Thorns")
		if thornsStacks > 0 and Mob and not Mob.isDead then
			local reflectPct = thornsProps.ReflectDamage or 0.15
			local reflectDmg = math.max(1, math.round(Damage * reflectPct * thornsStacks))
			
			-- Track Thorns Reflection Damage
			DamageLib:TagMobForDamage(Player, Mob, reflectDmg)
			Mob:TakeDamage(reflectDmg)
			CreateFloatingText("✦ Thorns", Color3.fromRGB(150, 255, 100), Mob.Instance)
		end

		-- Medusa
		local medusaProps, medusaStacks, medusaOmni = GetArmorEnchantmentProps(Player, "Medusa")
		if medusaStacks > 0 and Mob and not Mob.isDead then
			local chance = medusaProps.Chance or 0.10
			local finalChance = (chance * medusaStacks) + (chance * 1.5 * medusaOmni)

			if Random:NextNumber() <= finalChance then
				local stunTime = medusaProps.StunTime or 0.5
				RequestStunMob(Mob, stunTime)
				CreateFloatingText("✦ Medusa", Color3.fromRGB(200, 255, 150), Mob.Instance)
			end
		end
	end

	if Mob then Mob:RequestCallback("OnHitPlayer", {Player}) end

	EventModule:FireClient("MobDamagedPlayer", Player, CanDamage, DidNotInteract)
end

EventModule:GetOnServerEvent("PlayerDamaged"):Connect(function(Player, Damage, MobInstance)
	if typeof(Damage) ~= "number" or Damage ~= Damage or Damage < 0 then return end

	local CanHighlight = DamageLib.Hurt(Player, Damage, MobInstance)
	if CanHighlight then
		EventModule:FireClient("MobDamagedPlayer", Player, nil, Damage, nil, true, true)
	end
end)

