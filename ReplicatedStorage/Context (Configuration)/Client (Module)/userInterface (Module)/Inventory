	---- Cooldown UI ------------------------------------------------------------

	local CooldownTooltip = Player.PlayerGui:WaitForChild("Tooltip"):WaitForChild("Cooldown")

	local RecentlyActivatedTweens = {}
	local ActivatedCooldowns = {}
	local TweenGoal = 0

	local function CancelActivatedTweens()
		for _, Tween in RecentlyActivatedTweens do
			Tween:Cancel()
		end
		RecentlyActivatedTweens = {}
	end

	local function StopCooldown()
		CancelActivatedTweens()
		TweenGoal = os.clock()
		CooldownTooltip.Visible = false
	end

	local function StartCooldown(TotalTime, TimeLeft)
		for _, Section in CooldownTooltip.Ring:GetChildren() do
			Section.UIGradient.Rotation = 90
		end

		local Clock = os.clock()
		TweenGoal = Clock

		task.spawn(function()
			for Index, SectionName in {"TopRight", "TopLeft", "BottomLeft", "BottomRight"} do
				local Section = CooldownTooltip.Ring[SectionName]

				local NewTween = Tween:Play(Section.UIGradient, {TimeLeft / 4, "Linear"}, {Rotation = -1})
				table.insert(RecentlyActivatedTweens, NewTween)

				NewTween.Completed:Wait()

				if TweenGoal ~= Clock then
					break
				end
			end
		end)

		task.delay(TimeLeft, function()
			if TweenGoal == Clock then
				StopCooldown()
			end
		end)

		CooldownTooltip.Visible = true
	end

	local function CheckPlayerTool(Name, Tool)
		local Character = Player.Character
		local Tool = Tool or (Character and Character:FindFirstChildWhichIsA("Tool"))

		local isValidTool = Tool and Tool.Name == Name
		if isValidTool then
			local TimeLeft = math.max(0, ActivatedCooldowns[Tool.Name][1] - (os.clock() - ActivatedCooldowns[Tool.Name][2]))
			StartCooldown(ActivatedCooldowns[Tool.Name][1], TimeLeft)
		end
	end

	EventModule:GetOnEvent("PlayerUsedWeapon"):Connect(function(ItemCooldown, ToolOrName)
		if ItemCooldown < 0.15 then
			return
		end

		local function Play(Frame)
			local Cooldown = Frame.Cooldown
			Cooldown.BackgroundColor3 = GameConfig.BackgroundColor

			local Gradient = Cooldown.UIGradient
			Gradient.Offset = (ItemCooldown < 1 and Vector2.new(0, -1.3)) or Vector2.new(0, -1)

			Tween:Play(Cooldown, {0.1, "Quad", "InOut"}, {BackgroundTransparency = 0.3})
			Tween:Play(Gradient, {ItemCooldown, "Linear", "InOut"}, {Offset = Vector2.new(0, 0)})

			task.delay(ItemCooldown - 0.1, function()
				Tween:Play(Cooldown, {0.1, "Linear", "InOut"}, {BackgroundTransparency = 1})
			end)
		end

		local TargetKey = (typeof(ToolOrName) == "Instance") and GetSlotKey(ToolOrName) or ToolOrName

		if GameConfig.ShowMouseCooldownUI then
			local BaseName = (typeof(ToolOrName) == "Instance") and ToolOrName.Name or ToolOrName
			ActivatedCooldowns[BaseName] = {ItemCooldown, os.clock()}
			CheckPlayerTool(BaseName)
		end

		local Slot = Slots[TargetKey]
		if Slot then
			Play(Slot.Frame)
		end
	end)

	if GameConfig.ShowMouseCooldownUI then
		ContextActionService.LocalToolEquipped:Connect(function(Tool)
			if not ActivatedCooldowns[Tool.Name] then 
				return 
			end

			if os.clock() - ActivatedCooldowns[Tool.Name][2] < ActivatedCooldowns[Tool.Name][1] then
				CheckPlayerTool(Tool.Name, Tool)
			end
		end)

		ContextActionService.LocalToolUnequipped:Connect(function(Tool)
			StopCooldown()
		end)
	end

	---- BACKPACK LOGIC ------------------------------------------------------------

	local function UpdateItemCount()
		if Main.Parent == nil then
			return
		end

		local Count = 0
		for _, Value in pData.Items:GetDescendants() do
			if Value:IsA("Folder") then
				continue
			end

			if Value.ClassName == "NumberValue" then
				Count += Value.Value
			else
				Count += 1
			end
		end

		Main.Inventory.ItemLabel.Text = `({FormatNumber(Count, "Commas")} items)`
	end

	-- Unified Inventory State Tracker (Prevents Death/Reset UI Glitches)
	local function SetupPlayerInventoryState(Character: Model)
		local Humanoid = Character:WaitForChild("Humanoid") :: Humanoid
		local Backpack = Player:WaitForChild("Backpack", 5)

		-- Do NOT destroy the tool slots from the previous life
		-- Destroying them wipes the Hotbar; We just clear their dead physical references so the new tools can seamlessly link to them
		for _, Slot in pairs(Slots) do
			if Slot.ItemType and GameConfig.Categories[Slot.ItemType].IsATool then
				Slot.ItemInstance = nil
			end
		end

		EquippedTool = nil
		StartTimer = os.clock()

		if not Backpack then return end

		local function EnsureToolRegistered(Item: Instance)
			if not Item:IsA("Tool") then return end

			-- If the Server changes the tool's enchantments inline (like setting a Personal Waypoint), 
			-- this will seamlessly migrate the physical tool to a brand new UI slot
			if not Item:GetAttribute("EnchantListenerActive") then
				Item:SetAttribute("EnchantListenerActive", true)
				local lastSlotKey = GetSlotKey(Item)

				Item:GetAttributeChangedSignal("Enchantments"):Connect(function()
					local newSlotKey = GetSlotKey(Item)
					if newSlotKey == lastSlotKey then return end

					local oldSlot = Slots[lastSlotKey]
					if oldSlot and oldSlot.ItemInstance == Item then
						local replacement = nil
						for _, t in ipairs(Backpack:GetChildren()) do
							if t:IsA("Tool") and t ~= Item and GetSlotKey(t) == lastSlotKey then replacement = t; break end
						end
						if not replacement and Character then
							for _, t in ipairs(Character:GetChildren()) do
								if t:IsA("Tool") and t ~= Item and GetSlotKey(t) == lastSlotKey then replacement = t; break end
							end
						end

						if replacement then
							oldSlot.ItemInstance = replacement

							UpdateSlotState(oldSlot, false) 
						else
							oldSlot:Destroy()
						end
					end

					lastSlotKey = newSlotKey

					if not Slots[newSlotKey] then BackpackItemAdded:Fire(Item) else Slots[newSlotKey].ItemInstance = Item end
					if Item.Parent == Character then BackpackItemEquipped:Fire(Item) end
				end)
			end

			-- Match pure physical tools from the server with their enchanted data strings
			local ItemConfigObj = Item:FindFirstChild("ItemConfig")
			local ItemType = ItemConfigObj and require(ItemConfigObj).Type or "Tool"

			if ItemType and pData.Items:FindFirstChild(ItemType) then
				local enchantAttr = Item:GetAttribute("Enchantments")
				if not enchantAttr or enchantAttr == "" then

					-- Stop blank scrolls from stealing named scroll identities
					local matchedBlank = false
					local exactDataItem = pData.Items[ItemType]:FindFirstChild(Item.Name)

					if exactDataItem then
						local ownedCount = exactDataItem:IsA("NumberValue") and exactDataItem.Value or (exactDataItem:IsA("IntValue") and exactDataItem.Value or 1)
						local currentPhysicalCount = 0

						for _, t in ipairs(Character:GetChildren()) do
							if t:IsA("Tool") and GetSlotKey(t) == Item.Name then currentPhysicalCount += 1 end
						end
						for _, t in ipairs(Backpack:GetChildren()) do
							if t:IsA("Tool") and GetSlotKey(t) == Item.Name then currentPhysicalCount += 1 end
						end

						if currentPhysicalCount <= ownedCount then
							matchedBlank = true
						end
					end

					-- Only check for enchanted identities if no blank identity was available
					if not matchedBlank then
						for _, dataItem in ipairs(pData.Items[ItemType]:GetChildren()) do
							local splitName = string.split(dataItem.Name, "|")
							local baseName = splitName[1]

							if baseName == Item.Name and #splitName > 1 then
								local slotKey = dataItem.Name

								local ownedCount = dataItem:IsA("NumberValue") and dataItem.Value or (dataItem:IsA("IntValue") and dataItem.Value or 1)
								local currentPhysicalCount = 0

								for _, t in ipairs(Character:GetChildren()) do
									if t:IsA("Tool") and GetSlotKey(t) == slotKey then currentPhysicalCount += 1 end
								end
								for _, t in ipairs(Backpack:GetChildren()) do
									if t:IsA("Tool") and GetSlotKey(t) == slotKey then currentPhysicalCount += 1 end
								end

								-- Rely purely on physical counts. Do not use 'existingSlot', 
								-- as UI rendering delays will cause false-positive identity theft
								if currentPhysicalCount < ownedCount then
									local enchants = {}
									for i = 2, #splitName do table.insert(enchants, splitName[i]) end
									Item:SetAttribute("Enchantments", table.concat(enchants, ","))
									break
								end
							end
						end
					end
				end
			end

			UpdateItemCount()
			local SlotKey = GetSlotKey(Item)
			local Slot = Slots[SlotKey]
			if not Slot then
				BackpackItemAdded:Fire(Item)
			else
				if Slot.ItemInstance ~= Item then
					Slot.ItemInstance = Item
				end
			end
		end

		local function HandleToolEquipped(Item: Instance)
			if not Item:IsA("Tool") then return end
			UpdateItemCount()
			EnsureToolRegistered(Item)
			if EquippedTool ~= Item then
				EquippedTool = Item
				BackpackItemEquipped:Fire(Item)
			end
		end

		local function HandleToolUnequipped(Item: Instance)
			if not Item:IsA("Tool") then return end
			UpdateItemCount()
			EnsureToolRegistered(Item)
			if EquippedTool == Item then
				EquippedTool = nil
				BackpackItemUnequipped:Fire(Item)
			end
		end

		local function HandleToolRemoved(Item: Instance)
			if not Item:IsA("Tool") then return end
			task.defer(function()
				-- If it's truly gone from both the Backpack and Character, it was destroyed
				if Item.Parent ~= Backpack and Item.Parent ~= Character then
					UpdateItemCount()
					if EquippedTool == Item then EquippedTool = nil end

					-- Do NOT fire BackpackItemRemoved if the player is simply respawning
					-- If Humanoid is dead, the tools are just being wiped by Roblox's cleanup cycle. We safely ignore it
					if Humanoid and Humanoid.Health > 0 then
						BackpackItemRemoved:Fire(Item)
					end
				end
			end)
		end

		-- Initial state evaluation
		for _, Item in ipairs(Backpack:GetChildren()) do EnsureToolRegistered(Item) end
		for _, Item in ipairs(Character:GetChildren()) do HandleToolEquipped(Item) end

		-- Live Connections
		local conns = {}
		table.insert(conns, Backpack.ChildAdded:Connect(HandleToolUnequipped))
		table.insert(conns, Backpack.ChildRemoved:Connect(HandleToolRemoved))
		table.insert(conns, Character.ChildAdded:Connect(HandleToolEquipped))

		local charRemoved = Character.ChildRemoved:Connect(function(Child)
			if Child:IsA("Tool") then
				HandleToolRemoved(Child)
			else
				task.defer(function()
					local SlotKey = GetSlotKey(Child)
					local Slot = Slots[SlotKey]
					if not Slot then return end

					if not Child.Parent then
						-- Explicitly read from PlayerData using the SlotKey so enchanted variants aren't accidentally deleted on death
						local countVal = pData.Items[Slot.ItemType] and pData.Items[Slot.ItemType]:FindFirstChild(SlotKey)
						local Count = countVal and countVal.Value or 0

						if Count <= 0 then
							--  Only destroy the slot if the player is actually alive
							if Humanoid and Humanoid.Health > 0 then
								Slot:Destroy()
							end
						else
							UpdateSlotState(Slot, false)
						end
					else
						UpdateSlotState(Slot, false)
					end
				end)
			end
		end)
		table.insert(conns, charRemoved)

		local c1 = Humanoid.Died:Once(function()
			Humanoid:UnequipTools()
		end)

		Player.CharacterRemoving:Once(function()
			for _, c in ipairs(conns) do c:Disconnect() end
			if c1 then c1:Disconnect() end
		end)
	end

	Player.CharacterAdded:Connect(SetupPlayerInventoryState)
	if Player.Character then
		task.spawn(SetupPlayerInventoryState, Player.Character)
	end

