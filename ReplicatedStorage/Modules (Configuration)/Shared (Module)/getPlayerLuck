--[[
	getPlayerLuck
	
	Get luck modifier, modify this script in the event of anything new.
]]

--> Services
local ReplicatedStorage = game:GetService("ReplicatedStorage")

--> Dependencies
local GameConfig = require(ReplicatedStorage.GameConfig)

--------------------------------------------------------------------------------

return function(Player, Products)
	local AllocatedLuck = 1

	-- 1. Products / Gamepasses Calculation
	local ProductMultiplier = 0
	if Products then
		for _, Product in Products do
			local Buffs = Product.Buffs
			if (not Buffs) or (not Buffs.Luck) then
				continue
			end
			ProductMultiplier += Buffs.Luck
		end
	end

	-- Game luck configuration
	ProductMultiplier = GameConfig.LuckMultiplier * (1 + ProductMultiplier)
	AllocatedLuck = AllocatedLuck * ProductMultiplier

	-- 2. Potion / Status Effect Calculation
	if Player then
		local Statuses = Player:FindFirstChild("Statuses")
		local LuckStatus = Statuses and Statuses:FindFirstChild("Luck")

		if LuckStatus then
			local Duration = LuckStatus:GetAttribute("Duration") or 0
			local Boost = LuckStatus:GetAttribute("Boost") or 1

			-- Only apply if the potion is currently active
			if Duration > 0 then
				AllocatedLuck = AllocatedLuck * Boost
			end
		end
		
		-- Gambler Curse Luck Boost (+15%)
		local PlayerData = ReplicatedStorage:FindFirstChild("PlayerData")
		local pData = PlayerData and PlayerData:FindFirstChild(Player.UserId)
		local ActiveArmor = pData and pData:FindFirstChild("ActiveArmor")

		if ActiveArmor then
			for _, slot in ipairs({"Helmet", "Pauldron", "Chestplate"}) do
				if string.find(ActiveArmor[slot].Value, "Gambler") then
					AllocatedLuck = AllocatedLuck + 0.15
				end
			end
		end
	end

	return AllocatedLuck
end
