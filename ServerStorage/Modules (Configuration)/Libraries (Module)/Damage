-- Utilities

local function GetUserID(Player)
	local UserId = Player.UserId;
	if string.find(UserId, "-") then UserId = string.gsub(UserId, "-", "") end
	return UserId
end

local function GetPlayerBestDPS(Player)
	local Character = Player.Character
	local Weapons = {Character:FindFirstChildWhichIsA("Tool")}
	for _, Weapon in Player.Backpack:GetChildren() do
		table.insert(Weapons, Weapon)
	end

	local Selected = {}
	local BestDPS = 0
	for _, Weapon in Weapons do
		if Selected[Weapon.Name] then continue end
		Selected[Weapon.Name] = true

		local ItemConfig = Weapon:FindFirstChild("ItemConfig") and require(Weapon.ItemConfig)
		if ItemConfig and ItemConfig.Damage then
			local DPS = if typeof(ItemConfig.Damage) == "table" 
				then ((ItemConfig.Damage[1] + ItemConfig.Damage[2]) / 2) / ItemConfig.Cooldown 
				else ItemConfig.Damage / ItemConfig.Cooldown

			if DPS > BestDPS then
				BestDPS = DPS
			end
		end
	end

	return BestDPS
end

local function ShareDamageCallback(_Player, Name, Type, Params)
	EventModule:FireAllClients("ServerToClientCallback", _Player, Name, Type, Params)
	EventModule:Fire("ServerToServerCallback", _Player, Name, Type, Params)
end

local function GetToolEnchantmentProps(Tool, TargetFamily)
	if not Tool then return nil end
	local enchantAttr = Tool:GetAttribute("Enchantments")
	if not enchantAttr or enchantAttr == "" then return nil end

	local enchants = string.split(enchantAttr, ",")
	for _, enchantId in ipairs(enchants) do
		local config = ContentLibrary.Material[enchantId]
		if not config then
			for _, matData in pairs(ContentLibrary.Material) do
				if matData.Config and matData.Config.EnchantmentData and matData.Config.EnchantmentData.Id == enchantId then
					config = matData
					break
				end
			end
		end
		if config and config.Config.EnchantmentData then
			local family = config.Config.EnchantmentData.Family or string.split(enchantId, "_")[1]
			if family == TargetFamily then
				return config.Config.EnchantmentData.Properties
			end
		end
	end
	return nil
end

local function GetArmorEnchantmentProps(Player, TargetFamily)
	local pData = ReplicatedStorage.PlayerData:FindFirstChild(Player.UserId)
	local ActiveArmor = pData and pData:FindFirstChild("ActiveArmor")
	if not ActiveArmor then return nil, 0, 0 end

	local combinedProps = nil
	local stacks = 0
	local omniBoosts = 0

	for _, slot in ipairs({"Helmet", "Pauldron", "Chestplate"}) do
		local armorStr = ActiveArmor[slot].Value
		if armorStr ~= "" and string.find(armorStr, "|") then
			local split = string.split(armorStr, "|")
			local hasTarget = false

			for i = 2, #split do
				local enchantId = split[i]
				local config = ContentLibrary.Material[enchantId]
				if not config then
					for _, matData in pairs(ContentLibrary.Material) do
						if matData.Config and matData.Config.EnchantmentData and matData.Config.EnchantmentData.Id == enchantId then
							config = matData
							break
						end
					end
				end

				if config and config.Config.EnchantmentData then
					local family = config.Config.EnchantmentData.Family or string.split(enchantId, "_")[1]
					if family == TargetFamily then
						combinedProps = combinedProps or config.Config.EnchantmentData.Properties or {}
						hasTarget = true
						stacks += 1
					end
				end
			end

			-- Check if this specific armor piece also has Omniscience
			if hasTarget and string.find(armorStr, "Omniscience") then
				omniBoosts += 1
			end
		end
	end

	-- Returns: Properties, Total Stacks, Stacks on an item with Omniscience
	return combinedProps, stacks, omniBoosts
end

local function CreateFloatingText(text, color, instance)
	if not instance then return end
	local pivot = instance:GetPivot()

	local part = Instance.new("Part")
	part.Anchored = true
	part.CanCollide = false
	part.Transparency = 1
	part.CFrame = pivot
	part.Parent = workspace:FindFirstChild("Fx") or workspace

	local bg = Instance.new("BillboardGui")
	bg.Size = UDim2.fromOffset(150, 50)
	bg.StudsOffset = Vector3.new(0, 3, 0)
	bg.AlwaysOnTop = true
	bg.Parent = part

	local label = Instance.new("TextLabel")
	label.Size = UDim2.fromScale(1, 1)
	label.BackgroundTransparency = 1
	label.Text = text
	label.TextColor3 = color
	label.TextScaled = true
	label.FontFace = Font.new("rbxasset://fonts/families/Guru.json", Enum.FontWeight.Bold, Enum.FontStyle.Normal)
	label.Parent = bg

	local uiStroke = Instance.new("UIStroke")
	uiStroke.Thickness = 2
	uiStroke.Parent = label

	local endCFrame = part.CFrame * CFrame.new(0, 5, 0)
	local tweenInfo = TweenInfo.new(1.5, Enum.EasingStyle.Sine, Enum.EasingDirection.Out)
	local tween = TweenService:Create(part, tweenInfo, {CFrame = endCFrame})

	TweenService:Create(label, tweenInfo, {TextTransparency = 1}):Play()
	TweenService:Create(uiStroke, tweenInfo, {Transparency = 1}):Play()

	tween:Play()
	Debris:AddItem(part, 1.5)
end

