	---- Items

	for _, Category in Items:GetChildren() do
		-- 1. Initial Load Loop
		for _, DataValue in Category:GetChildren() do
			local splitName = string.split(DataValue.Name, "|")
			local baseName = splitName[1]

			local Item = ContentLibrary[Category.Name][baseName]
			if not Item then continue end

			local slotKey = DataValue.Name
			if Slots[slotKey] then
				continue
			end

			-- Create a clone and apply enchantments so Slot.new can read them
			local MockInstance = Item.Instance:Clone()
			if #splitName > 1 then
				local enchants = {}
				for i = 2, #splitName do table.insert(enchants, splitName[i]) end
				MockInstance:SetAttribute("Enchantments", table.concat(enchants, ","))
			end

			task.spawn(Slot.new, MockInstance)
		end

		-- 2. Added Item Event
		Category.ChildAdded:Connect(function(DataValue)
			local splitName = string.split(DataValue.Name, "|")
			local baseName = splitName[1]

			local Item = ContentLibrary[Category.Name][baseName]
			if not Item then return end

			local slotKey = DataValue.Name
			if Slots[slotKey] then return end

			-- Create a clone and apply enchantments
			local MockInstance = Item.Instance:Clone()
			if #splitName > 1 then
				local enchants = {}
				for i = 2, #splitName do table.insert(enchants, splitName[i]) end
				MockInstance:SetAttribute("Enchantments", table.concat(enchants, ","))
			end

			local newSlot = Slot.new(MockInstance)
			local CategoryConfig = GameConfig.Categories[Item.Type]
			local HotbarSlot = GetNextHotbarSlot()

			if newSlot and HotbarSlot and not DataValue:GetAttribute("DontSave") and not CategoryConfig.AmountOnly then
				-- Do not push to hotbar if the item is already equipped (prevents ghost slots when upgrading equipped items)
				if not IsItemEquipped(slotKey) then
					newSlot:PushToHotbar(HotbarSlot)
				end
			end
		end)

		-- 3. Removed Item Event
		Category.ChildRemoved:Connect(function(DataValue)
			local slotKey = DataValue.Name

			-- If the consumed/upgraded item was equipped, forcefully clear it to sync the Server
			if IsItemEquipped(slotKey) then
				if Category.Name == "Armor" then EventModule:InvokeServer("UnequipArmor", slotKey) end
				if Category.Name == "Accessory" then EventModule:InvokeServer("UnequipAccessory", slotKey) end
				if Category.Name == "Orb" then EventModule:InvokeServer("UnequipOrb", slotKey) end

				-- Manually trigger your refresh function so the Equipment UI instantly clears
				task.delay(0.1, RefreshEquipmentUI) 
			end

			local slot = Slots[slotKey]
			if slot then
				slot:Destroy()
			end
		end)
