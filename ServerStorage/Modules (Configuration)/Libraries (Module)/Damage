function DamageLib:TagMobForDamage(Player: Player, Mob, Damage: number)
	if Mob.isDead then return end

	local UserId = GetUserID(Player)

	if Mob.Config.InstantRefreshData and Mob.Config.InstantRefreshData.CanRefresh then
		local RegenerateTag = Mob.Instance:FindFirstChild("RegenerateTag") or Instance.new("Configuration")
		RegenerateTag.Name = "RegenerateTag"
		RegenerateTag.Parent = Mob.Instance

		if RegenerateTag:GetAttribute("Player") == nil or RegenerateTag:GetAttribute("Player") == Player then
			RegenerateTag:SetAttribute("Clock", os.clock())
			RegenerateTag:SetAttribute("PlayerID", UserId)
		end
	end

	local PlayerTags = Mob.Instance:FindFirstChild("PlayerTags")
	if not PlayerTags then
		PlayerTags = Instance.new("Configuration")
		PlayerTags.Name = "PlayerTags"
		PlayerTags.Parent = Mob.Instance
	end

	local ExistingTag = PlayerTags:GetAttribute(tonumber(UserId))
	PlayerTags:SetAttribute(tonumber(UserId), (ExistingTag or 0) + Damage)
end

function DamageLib:DamageMob(Player: Player, Mob, Parameters)
	Parameters = Parameters or {}

	local NoHitSound = Parameters.NoHitSound 
	local Multiplier = Parameters.Multiplier
	local ClassType = Parameters.ClassType
	local Damage = Parameters.Damage
	local Ignore = Parameters.Ignore 
	local Dampen = Parameters.Dampen
	local Tool = Parameters.Tool

	local UserId = GetUserID(Player)
	local RegenerateTag = Mob.Instance:FindFirstChild("RegenerateTag")

	if Mob.isDead or (Mob.Config.InstantRefreshData and Mob.Config.InstantRefreshData.CanRefresh and RegenerateTag and (RegenerateTag:GetAttribute("PlayerID") ~= UserId and RegenerateTag:GetAttribute("PlayerID") ~= nil)) then
		return
	end

	local Character = Player.Character
	local Humanoid = Character and Character:FindFirstChild("Humanoid") :: Humanoid
	if not Humanoid or Humanoid.Health <= 0 then return end

	local Tool = Tool or Character:FindFirstChildOfClass("Tool")
	local ItemConfig = Tool and Tool:FindFirstChild("ItemConfig") and require(Tool.ItemConfig)
	if (not ItemConfig or not ItemConfig.Damage or ItemConfig.WeaponType ~= ClassType) and not Ignore then return end

	local Count = Interactions[Player.UserId]
	local Default = GameConfig.MaxDamageInteractions[1]

	-- Sync Server Cooldown check with Haste
	local serverCooldown = ItemConfig and ItemConfig.Cooldown
	if serverCooldown then
		local hasteProps = GetToolEnchantmentProps(Tool, "Haste")
		if hasteProps then
			serverCooldown = serverCooldown * (1 - (hasteProps.CooldownReduction or 0.10))
		end
	end

	if not Ignore and ItemConfig and serverCooldown and (Count and (Count > Default / serverCooldown)) then return end

	Interactions[Player.UserId] = (Count and Count + 1) or 1

	local ItemSuite = ItemConfig and ItemConfig.Suite and ItemConfig.Suite[2]
	local CriticalChance = ItemConfig and ItemConfig.CriticalChance or GameConfig.CriticalChance
	local CriticalDamage = GameConfig.CriticalMultiplier

	if CriticalChance[2] then
		local UnitCriticalChance = {1, CriticalChance[2] / CriticalChance[1]}
		for _, Callback in CriticalModifiers do
			UnitCriticalChance, CriticalDamage = Callback(Player, Tool, UnitCriticalChance, CriticalDamage)
		end
	end

	local Proportionate = ItemSuite and ItemSuite.Proportionate
	local SuiteDamage = ItemSuite and ItemSuite.Damage

	local Damage = Damage 
		or Proportionate and GetPlayerBestDPS(Player) * ItemSuite.Damage
		or SuiteDamage
		or typeof(ItemConfig.Damage) == "table" and Random:NextInteger(unpack(ItemConfig.Damage))
		or ItemConfig.Damage

	-- Apply Sharpness
	local SharpnessProps = GetToolEnchantmentProps(Tool, "Sharpness")
	if SharpnessProps then
		Damage = Damage * (1 + (SharpnessProps.DamagePercent or 0))
	end
	
	-- Apply Curse Modifiers
	local DavidProps = GetToolEnchantmentProps(Tool, "David")
	if DavidProps then Damage = Damage * (1 + (DavidProps.DamagePercent or 1)) end

	local SlothProps = GetToolEnchantmentProps(Tool, "Sloth")
	if SlothProps then Damage = Damage * (1 + (SlothProps.DamagePercent or 1)) end

	local ParasiteProps = GetToolEnchantmentProps(Tool, "Parasite")
	if ParasiteProps then Damage = Damage * (1 + (ParasiteProps.DamagePercent or 0.50)) end

	local GreedProps = GetToolEnchantmentProps(Tool, "Greed")
	if GreedProps then Damage = Damage * (1 - (GreedProps.DamageReduction or 0.25)) end

	-- Check armor for Goliath
	local pData = ReplicatedStorage.PlayerData:FindFirstChild(Player.UserId)
	local ActiveArmor = pData and pData:FindFirstChild("ActiveArmor")
	if ActiveArmor then
		for _, slot in ipairs({"Helmet", "Pauldron", "Chestplate"}) do
			local armorName = ActiveArmor[slot].Value
			if string.find(armorName, "Goliath") then
				Damage = Damage * 0.85
			end
		end
	end

	if Tool then
		for _, Callback in DamageModifiers do
			Damage = Callback(Player, Tool, Damage, Mob)
		end
	end

	-- Defense negation
	local ConfigDefensePenetration = ItemConfig and ItemConfig.DefensePenetration
	local ConfigDefense = Mob.Config.Defense

	local WeaponCanAdd = ConfigDefensePenetration and ConfigDefensePenetration[2]
	local WeaponDefense = ConfigDefensePenetration and ConfigDefensePenetration[1]
	if not WeaponCanAdd then
		WeaponDefense = WeaponDefense and math.clamp(WeaponDefense, 0, 1)
	end

	local MobCanAdd = ConfigDefense and ConfigDefense[2]
	local MobDefense = ConfigDefense and ConfigDefense[1]
	if not MobCanAdd then
		MobDefense = MobDefense and math.clamp(MobDefense, 0, 1)
	end

	local RawMobDefense = (MobCanAdd and MobDefense) or 0
	local RawWeaponDefense = (WeaponCanAdd and WeaponDefense) or 0
	if MobDefense and not MobCanAdd then
		local DividedMobDefense = (1 / MobDefense)
		if WeaponDefense and not WeaponCanAdd then
			DividedMobDefense *= (1 / WeaponDefense)
		end
		local NegatedWeaponDamage = Damage / DividedMobDefense
		RawMobDefense = NegatedWeaponDamage
	end

	RawMobDefense = math.clamp(RawMobDefense - RawWeaponDefense, 0, math.huge)
	Damage = math.clamp(Damage - RawMobDefense, 1, math.huge)

	if Dampen and Dampen == Dampen then
		local ClampedDampen = math.clamp(Dampen, 0.1, 1)
		Damage = Damage * ClampedDampen
	end

	local Critical = CriticalChance[2] and Random:NextInteger(unpack(CriticalChance)) == CriticalChance[2]
	if Critical then
		Damage *= CriticalDamage
	end

	if typeof(Multiplier) == "number" then
		Damage *= Multiplier
	end

	local MaxDamageCap = Mob.Config.MaxDamageCap 
	if MaxDamageCap then
		local MaxDamage = math.round(Mob.Config.Health * MaxDamageCap)
		Damage = math.clamp(Damage, 0, MaxDamage)
	end

	-- Execute Enchantment
	local ExecuteProps = GetToolEnchantmentProps(Tool, "Execute")
	if ExecuteProps then
		local threshold = ExecuteProps.Threshold or 0.10
		local mobHum = Mob.Instance:FindFirstChildWhichIsA("Humanoid")
		if mobHum and (mobHum.Health - Damage) <= (mobHum.MaxHealth * threshold) and (mobHum.Health - Damage) > 0 then
			Damage = mobHum.Health -- Instant Kill

			-- Check for a custom Execute particle folder and apply it to the mob's limbs
			local executeFX = ReplicatedStorage.Assets.Effects.Execute
			if executeFX then
				for _, limb in ipairs({"Left Leg", "Left Arm", "Right Arm", "Right Leg", "Torso", "Head"}) do
					local part = Mob.Instance:FindFirstChild(limb)
					if part then
						for _, particle in ipairs(executeFX:GetChildren()) do
							local clone = particle:Clone()
							clone.Parent = part
							clone.Enabled = true

							task.delay(1, function()
								if clone then clone.Enabled = false end
							end)
							Debris:AddItem(clone, 3)
						end
					end
				end
			end

			-- Add the red flash highlight as well
			local highlight = Instance.new("Highlight")
			highlight.FillColor = Color3.fromRGB(255, 0, 0)
			highlight.Parent = Mob.Instance
			Debris:AddItem(highlight, 0.5)
			
			CreateFloatingText("✦ Execute", Color3.fromRGB(255, 0, 0), Mob.Instance)
		end
	end

	Damage = math.round(Damage)

	local CharacterPivot = Character:GetPivot().Position
	local MobPivot = Mob.Instance:GetPivot().Position

	-- Apply slight knockback to the mob (Defaults to 5 if weapon doesn't specify one)
	local KnockbackPower = (not Multiplier and ItemConfig and ItemConfig.Knockback) or 3.5
	local mobTorso = Mob.Instance:FindFirstChild("Torso") or Mob.Instance:FindFirstChild("UpperTorso") or Mob.Instance:FindFirstChild("HumanoidRootPart")

	if mobTorso then
		Knockback:Activate(mobTorso, KnockbackPower, CharacterPivot, MobPivot)
	end

	AttributeModule:SetAttribute(Mob.Instance, "HasBeenHit", true)

	DamageLib:TagMobForDamage(Player, Mob, Damage)
	
	-- Scavenger Proc (Mobs)
	local ScavengerProps = GetToolEnchantmentProps(Tool, "Scavenger")
	if ScavengerProps then
		local chance = ScavengerProps.Chance or 0.05
		if Tool:GetAttribute("Enchantments") and string.find(Tool:GetAttribute("Enchantments"), "Omniscience") then chance *= 1.5 end

		if Random:NextNumber() <= chance then
			local pData = ReplicatedStorage.PlayerData:FindFirstChild(Player.UserId)
			local goldStat = pData and pData.Stats:FindFirstChild("Gold")
			if goldStat then
				goldStat.Value += (ScavengerProps.Amount or 5)
				CreateFloatingText("✦ Scavenger", Color3.fromRGB(255, 215, 0), Mob.Instance)
			end
		end
	end
	
	-- Guillotine Damage Tracking
	local deathmark = Mob.Instance:GetAttribute("GuillotineMark")
	if deathmark then
		Mob.Instance:SetAttribute("GuillotineDamage", (Mob.Instance:GetAttribute("GuillotineDamage") or 0) + Damage)
	end

	Mob:TakeDamage(Damage)

	if Tool then
		local enchantAttr = Tool:GetAttribute("Enchantments")
		if enchantAttr and enchantAttr ~= "" then
			local enchants = string.split(enchantAttr, ",")
			for _, enchantId in ipairs(enchants) do
				EnchantSuite:OnHit(Player, Mob, Damage, enchantId)
			end
		end
	end
	
	-- Hit & Crit VFX 
	local effectName = Critical and "Crit" or "Hit"
	local fxPrefab = ReplicatedStorage.Assets.Effects:FindFirstChild(effectName)
	if fxPrefab then
		local targetPart = Mob.Instance:FindFirstChild("Torso")
		if targetPart then
			for _, particle in ipairs(fxPrefab:GetChildren()) do
				local clone = particle:Clone()
				clone.Parent = targetPart
				clone.Enabled = true

				-- Turn off emission quickly for a burst effect
				task.delay(0.3, function()
					if clone then clone.Enabled = false end
				end)
				Debris:AddItem(clone, 1)
			end
		end
	end

	Mob:RequestCallback("OnHit", {Player})

	EventModule:FireClient("PlayerDamagedEntity", Player, Mob.Instance, Damage, Critical, ItemConfig, NoHitSound)

	if Tool and ClassType ~= "Orb" then
		if Critical then
			ShareDamageCallback(Player, Tool.Name, "OnCritical", {Tool, Mob.Instance})
		end
		ShareDamageCallback(Player, Tool.Name, "OnHit", {Tool, Mob.Instance})
	end
end

function DamageLib:DamageProp(Player: Player, Prop, Parameters)
	Parameters = Parameters or {}

	local Damage = Parameters.Damage
	local Ignore = Parameters.Ignore 
	local Tool = Parameters.Tool
	local IgnoreExcavator = Parameters.IgnoreExcavator

	local Character = Player.Character
	Tool = Tool or Character and Character:FindFirstChildOfClass("Tool")

	if Prop.isDead then return end

	local ItemConfig = Tool and Tool:FindFirstChild("ItemConfig") and require(Tool.ItemConfig)
	if (not ItemConfig or not ItemConfig.Damage or not ItemConfig.ValidPropTypes or not table.find(ItemConfig.ValidPropTypes, Prop.Config.PropType)) and not Ignore then 
		return 
	end

	-- Calculate base damage early so enchantments don't multiply by nil
	Damage = Damage 
		or (typeof(ItemConfig.Damage) == "table" and Random:NextInteger(unpack(ItemConfig.Damage)))
		or ItemConfig.Damage

	-- Sync Server Cooldown check with Haste (Prop Anti-Cheat)
	local Count = Interactions[Player.UserId]
	local Default = GameConfig.MaxDamageInteractions[1]
	local serverCooldown = ItemConfig and ItemConfig.Cooldown
	if serverCooldown then
		local hasteProps = GetToolEnchantmentProps(Tool, "Haste")
		if hasteProps then
			serverCooldown = serverCooldown * (1 - (hasteProps.CooldownReduction or 0.10))
		end
	end

	if not Ignore and ItemConfig and serverCooldown and (Count and (Count > Default / serverCooldown)) then return end
	Interactions[Player.UserId] = (Count and Count + 1) or 1

	-- Cheater Tier Bypass
	local CheaterProps = GetToolEnchantmentProps(Tool, "Cheater")
	local TierBoost = CheaterProps and (CheaterProps.TierBoost or 1) or 0

	if (ItemConfig.Tier + TierBoost) < Prop.Config.Tier then
		EventModule:FireClient("PlayerDamagedEntity", Player, Prop.Instance, "Tier too low!", GameConfig.WarningColor, ItemConfig.InvalidSFX or GameConfig.InvalidSFX)
		return
	end
	
	-- Tempered Enchantment
	local TemperedProps = GetToolEnchantmentProps(Tool, "Tempered")
	if TemperedProps then
		local chance = TemperedProps.Chance or 0.15
		if Tool:GetAttribute("Enchantments") and string.find(Tool:GetAttribute("Enchantments"), "Omniscience") then chance *= 1.5 end

		if Random:NextNumber() <= chance then
			Damage = Damage * 2
			CreateFloatingText("✦ Tempered", Color3.fromRGB(255, 100, 0), Prop.Instance)
		end
	end

	-- Excavator AoE Loop
	if not IgnoreExcavator then
		local ExcavatorProps = GetToolEnchantmentProps(Tool, "Excavator")
		if ExcavatorProps then
			local radius = ExcavatorProps.Radius or 20

			-- Ensure base Damage is calculated before trying to multiply it
			Damage = Damage 
				or (typeof(ItemConfig.Damage) == "table" and Random:NextInteger(unpack(ItemConfig.Damage)))
				or ItemConfig.Damage

			-- Define the AoE damage (Defaults to 100% of original Damage if no percent is set)
			local aoePct = ExcavatorProps.DamagePercent or 1
			local aoeDmg = math.max(1, math.round(Damage * aoePct))

			local overlapParams = OverlapParams.new()
			overlapParams.FilterType = Enum.RaycastFilterType.Include

			local propFolders = {}
			for _, tagged in ipairs(CollectionService:GetTagged("Prop")) do table.insert(propFolders, tagged) end
			overlapParams.FilterDescendantsInstances = propFolders

			local hitParts = workspace:GetPartBoundsInRadius(Prop.Instance:GetPivot().Position, radius, overlapParams)
			local processedProps = { [Prop.Instance] = true }

			for _, part in ipairs(hitParts) do
				local nearbyPropInstance = part:FindFirstAncestorWhichIsA("Model")

				if nearbyPropInstance and not processedProps[nearbyPropInstance] and CollectionService:HasTag(nearbyPropInstance, "Prop") then
					processedProps[nearbyPropInstance] = true

					local nearbyProp = Props[nearbyPropInstance]

					-- Ensure the prop is fully loaded and its methods haven't been wiped
					if nearbyProp and nearbyProp.TakeDamage then
						nearbyPropInstance:SetAttribute("JustExcavated", true)

						-- Apply AoE damage safely
						task.spawn(function()
							-- Double check that it didn't die exactly as the thread yielded
							if nearbyProp and nearbyProp.TakeDamage then
								DamageLib:DamageProp(Player, nearbyProp, {
									Tool = Tool,
									Damage = aoeDmg,
									IgnoreExcavator = true
								})
							end
						end)

						task.delay(0.1, function()
							if nearbyPropInstance then nearbyPropInstance:SetAttribute("JustExcavated", nil) end
						end)
					end
				end
			end
		end
	end

	-- Bless Check (Swaps the node with its Blessed version)
	local BlessProps = GetToolEnchantmentProps(Tool, "Bless")
	if BlessProps and not Prop.Instance:GetAttribute("IsBlessed") then
		if Random:NextNumber() <= (BlessProps.BlessChance or 0.05) then
			local propType = Prop.Config.PropType
			local folderName = (propType == "Ore" and "Ores") or (propType == "Plant" and "Plants") or (propType .. "s")

			local typeFolder = ReplicatedStorage.Assets.Props:FindFirstChild(folderName)
			local blessedFolder = typeFolder and typeFolder:FindFirstChild("Blessed")
			local blessedPrefab = blessedFolder and blessedFolder:FindFirstChild("Shiny " .. Prop.Instance.Name)

			if blessedPrefab then
				Prop.Instance:SetAttribute("IsBlessed", true) -- Prevent looping

				local newPropModel = blessedPrefab:Clone()
				newPropModel:SetAttribute("IsBlessed", true)
				newPropModel:PivotTo(Prop.Instance:GetPivot())

				task.defer(function()
					newPropModel.Parent = workspace.Props
					CollectionService:AddTag(newPropModel, "Prop")
					Prop:Destroy()
				end)

				EventModule:FireClient("SendNotification", Player, "Blessed!", "You discovered a Shiny node!", 0)
				CreateFloatingText("✦ Bless", Color3.fromRGB(255, 255, 255), Prop.Instance)
				return -- Skip damaging the current prop since it was just replaced!
			end
		end
	end

	-- Reroll Check (Rerolls the prop to another of the SAME TYPE)
	local RerollProps = GetToolEnchantmentProps(Tool, "Reroll")
	if RerollProps and not Prop.Instance:GetAttribute("HasRerolled") then
		if Random:NextNumber() <= (RerollProps.RerollChance or 0.05) then
			Prop.Instance:SetAttribute("HasRerolled", true)

			local propType = Prop.Config.PropType
			local folderName = (propType == "Ore" and "Ores") or (propType == "Plant" and "Plants") or (propType .. "s")
			local typeFolder = ReplicatedStorage.Assets.Props:FindFirstChild(folderName)

			if typeFolder then
				local availableProps = {}

				-- Loop through the folder and ONLY grab Models (ignores the 'Blessed' / 'Special' folders)
				for _, child in ipairs(typeFolder:GetChildren()) do 
					if child:IsA("Model") and child.Name ~= Prop.Instance.Name then
						table.insert(availableProps, child) 
					end
				end

				if #availableProps > 0 then
					local chosenPrefab = availableProps[Random:NextInteger(1, #availableProps)]
					local newPropModel = chosenPrefab:Clone()
					newPropModel:SetAttribute("HasRerolled", true)
					newPropModel:PivotTo(Prop.Instance:GetPivot())

					task.defer(function()
						newPropModel.Parent = workspace.Props
						CollectionService:AddTag(newPropModel, "Prop")
						Prop:Destroy()
					end)

					EventModule:FireClient("SendNotification", Player, "Rerolled!", "The node rerolled into " .. chosenPrefab.Name .. "!", 0)
					CreateFloatingText("✦ Reroll", Color3.fromRGB(0, 255, 127), newPropModel)
					return -- Skip damaging the current prop since it was just replaced!
				end
			end
		end
	end

	local currentTime = os.time()
	if Prop.OwnerUserId and Prop.OwnerUserId ~= Player.UserId then
		if (currentTime - Prop.LastHitTime) < 10 then
			EventModule:FireClient("PlayerDamagedEntity", Player, Prop.Instance, "No Stealing!", GameConfig.WarningColor)
			return 
		end
	end

	Prop.OwnerUserId = Player.UserId
	Prop.LastHitTime = currentTime
	
	-- Scavenger Proc (Props)
	local ScavengerProps = GetToolEnchantmentProps(Tool, "Scavenger")
	if ScavengerProps then
		local chance = ScavengerProps.Chance or 0.05
		if Tool:GetAttribute("Enchantments") and string.find(Tool:GetAttribute("Enchantments"), "Omniscience") then chance *= 1.5 end

		if Random:NextNumber() <= chance then
			local pData = ReplicatedStorage.PlayerData:FindFirstChild(Player.UserId)
			local goldStat = pData and pData.Stats:FindFirstChild("Gold") or pData and pData.Stats:FindFirstChild("Coins")
			if goldStat then
				goldStat.Value += (ScavengerProps.Amount or 5)
				CreateFloatingText("✦ Scavenger", Color3.fromRGB(255, 215, 0), Prop.Instance)
			end
		end
	end

	local Damage = Damage 
		or typeof(ItemConfig.Damage) == "table" and Random:NextInteger(unpack(ItemConfig.Damage))
		or ItemConfig.Damage

	-- Apply Sharpness
	local SharpnessProps = GetToolEnchantmentProps(Tool, "Sharpness")
	if SharpnessProps then
		Damage = Damage * (1 + (SharpnessProps.DamagePercent or 0))
	end

	for _, Callback in DamageModifiers do
		Damage = Callback(Player, Tool, Damage)
	end

	Damage = math.round(Damage)

	local CurrentDamage = Prop.PlayerTags[Player.UserId] or 0
	Prop.PlayerTags[Player.UserId] = CurrentDamage + Damage

	Prop:TakeDamage(Damage)

	EventModule:FireClient("PlayerDamagedEntity", Player, Prop.Instance, Damage, false, ItemConfig, false, Prop.Scale)
	ShareDamageCallback(Player, Tool.Name, "OnHit", {Tool, Prop.Instance})
end

function DamageLib.CallDamage(Player, EntityInstance: Model, Dampen: number?, Class)
	if not EntityInstance or typeof(EntityInstance) ~= "Instance" then return end

	if CollectionService:HasTag(EntityInstance, "Mob") then
		local Mob = Mobs[EntityInstance]
		if Mob then
			DamageLib:DamageMob(Player, Mob, {Dampen = Dampen, ClassType = Class})
		end
	elseif CollectionService:HasTag(EntityInstance, "Prop") then
		local Prop = Props[EntityInstance]
		if Prop then
			DamageLib:DamageProp(Player, Prop)
		end
	end
end

EventModule:GetOnServerEvent("RequestPlayerStun"):Connect(function(Player, StunTime)
	if type(StunTime) ~= "number" then return end
	if Player.Character then
		RequestStunMob(Player.Character, math.clamp(StunTime, 0, 5))
	end
end)

EventModule:GetOnServerEvent("DamageEntity"):Connect(DamageLib.CallDamage)
return DamageLib
