	-- Refresh all armor slots initially
	RefreshEquipmentUI()

	local function UpdateKeybinds(Equipment, Verdict)
		local Keybinds = Equipment 
			and Equipment.Config 
			and Equipment.Config.Keybinds

		if not Keybinds then
			return
		end

		for Key, Data in Keybinds do
			KeybindSystem:UpdateKeybind(Key, Data[1], Verdict, Data[2], Data[3], Data[4], {
				Type = Equipment.Config.Type, Name = Equipment.Name
			})
		end
	end

	local function CheckActiveArmor()
		-- We need to check all 3 slots
		for _, SlotName in ipairs({"Helmet", "Pauldron", "Chestplate"}) do
			local CurrentName = activeArmorData[SlotName].Value
			local Equipped = CurrentName ~= ""
			local PreviousName = lastActiveArmor[SlotName]

			-- Unequip previous
			if PreviousName and PreviousName ~= "" and PreviousName ~= CurrentName then
				local baseName = string.split(PreviousName, "|")[1]
				local Item = ContentLibrary.Armor[baseName]
				local Slot = Slots[PreviousName]

				if Slot then 
					UpdateSlotState(Slot, false) 
					Slot.Frame.Visible = true
				end
				if Item then UpdateKeybinds(Item, false) end
			end

			-- Equip current
			if Equipped then
				local baseName = string.split(CurrentName, "|")[1]
				local Item = ContentLibrary.Armor[baseName]
				local Slot = Slots[CurrentName]

				-- If equipping from hotbar, eject it first so it doesn't take up the slot
				if Slot and isSlotInHotbar(Slot) then Slot:PushToInventory() end
				if Slot then 
					UpdateSlotState(Slot, true) 
					Slot.Frame.Visible = false
				end
				if Item then UpdateKeybinds(Item, true) end
			end
			lastActiveArmor[SlotName] = CurrentName
		end
	end

	-- Connect to all 3 slots
	activeArmorData.Helmet.Changed:Connect(CheckActiveArmor)
	activeArmorData.Pauldron.Changed:Connect(CheckActiveArmor)
	activeArmorData.Chestplate.Changed:Connect(CheckActiveArmor)
	task.spawn(CheckActiveArmor)

	local EquippedSlots = pData:WaitForChild("EquippedSlots")
	for _, Slot in EquippedSlots:GetChildren() do
		local LastEquipped = Slot.Value
		if LastEquipped ~= "" then
			local baseName = string.split(LastEquipped, "|")[1]
			task.defer(UpdateKeybinds, ContentLibrary.Accessory[baseName], true)
		end

		local function OnUpdatedValue()
			local Equipped = Slot.Value ~= "" 
			local _Slot = (Equipped and Slots[Slot.Value]) or (LastEquipped and Slots[LastEquipped])
			if _Slot then
				if Equipped and isSlotInHotbar(_Slot) then _Slot:PushToInventory() end

				local baseName = string.split(_Slot.ItemInstance.Name, "|")[1]
				UpdateKeybinds(ContentLibrary.Accessory[baseName], Equipped)
				UpdateSlotState(_Slot, Equipped)
				_Slot.Frame.Visible = not Equipped
			end
			LastEquipped = Slot.Value
		end
		Slot.Changed:Connect(OnUpdatedValue)
		OnUpdatedValue()
	end

	local EquippedOrbs = pData:WaitForChild("EquippedOrbs")
	for _, Slot in EquippedOrbs:GetChildren() do
		local LastEquipped = Slot.Value
		if LastEquipped ~= "" then
			local baseName = string.split(LastEquipped, "|")[1]
			task.defer(UpdateKeybinds, ContentLibrary.Orb[baseName], true)
