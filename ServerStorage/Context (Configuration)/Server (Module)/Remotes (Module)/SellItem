--> Services
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local ServerStorage = game:GetService("ServerStorage")

--> References
local PlayerData = ReplicatedStorage:WaitForChild("PlayerData")

--> Dependencies
local ContentLibrary = require(ReplicatedStorage.Modules.Shared.ContentLibrary)
local RemoveItemWithAmount = require(ServerStorage.Modules.Server.removeItemWithAmount)
local GameConfig = require(ReplicatedStorage.GameConfig)

--> Variables
local Remotes = {}

local Libraries = {}
for _, Module in ServerStorage.Modules.Libraries["items [Subcategories]"]:GetChildren() do
	Libraries[Module.Name] = require(Module)
end

--------------------------------------------------------------------------------

if not GameConfig.EnabledFeatures.PawnShop then
	return {}
end

local function ParseCompoundName(compoundName)
	local split = string.split(tostring(compoundName), "|")
	local baseName = split[1]
	local enchants = {}
	for i = 2, #split do table.insert(enchants, split[i]) end
	return baseName, enchants
end

-- Callbacks
local function GiveMultipleOfItem(Player, ItemType: string, ItemName: string, Amount: number)
	local pData = PlayerData:FindFirstChild(Player.UserId)
	local Item = ContentLibrary[ItemType] and ContentLibrary[ItemType][ItemName]
	if not Item then return end

	Libraries[ItemType]:Give(Player, Item, nil, "Force", Amount)
	return true
end

local function SellMultipleOfItem(Player, ItemType: string, CompoundItemName: string, BaseItemName: string, Amount: number)
	local pData = PlayerData:WaitForChild(Player.UserId)
	local Item = ContentLibrary[ItemType] and ContentLibrary[ItemType][BaseItemName]
	if not Item then return end

	Amount = math.min(Amount, GameConfig.Categories[Item.Type].BulkSellMax)

	-- Use RemoveItemWithAmount to safely delete the exact enchanted variant
	RemoveItemWithAmount(Player, ItemType, CompoundItemName, Amount)

	-- Add currency
	local SellType = Item.Config.Sell and Item.Config.Sell[1] or Item.Config.Cost[1]
	local SellName = Item.Config.Sell and Item.Config.Sell[2] or Item.Config.Cost[2]

	local Return = Item.Config.Sell and Item.Config.Sell[3] or math.floor(Item.Config.Cost[3] / 2)
	local GivenAmount = Return * Amount

	if SellType == "Statistic" then
		local Currency = pData.Stats[SellName]
		if Currency then
			Currency.Value += GivenAmount
		end
	else
		GiveMultipleOfItem(Player, SellType, SellName, GivenAmount)
	end

	return true
end

-- Modify this function in order to change remote callback
function Remotes:OnEvent(Player, ItemType: string, CompoundItemName: string, Amount: number)
	if not ItemType or not CompoundItemName then return end
	if typeof(ItemType) ~= "string" or typeof(CompoundItemName) ~= "string" then return end

	local pData = PlayerData:FindFirstChild(Player.UserId)

	-- Parse the compound name so we can read the base configuration
	local BaseItemName, enchants = ParseCompoundName(CompoundItemName)
	local Item = ContentLibrary[ItemType] and ContentLibrary[ItemType][BaseItemName]

	if not pData or not Item then return end

	if not Item.Config.Sell and (not Item.Config.Cost or not GameConfig.SellShopItems) then
		return false, "This item can't be sold"
	end

	-- Check if they own the exact compound variant
	local itemValue = pData.Items[ItemType]:FindFirstChild(CompoundItemName)
	if not itemValue or itemValue.Value < 1 then
		return false, "You don't own this item"
	end

	local finalAmount = Amount and typeof(Amount) == "number" and Amount or 1

	return SellMultipleOfItem(Player, ItemType, CompoundItemName, BaseItemName, finalAmount)
end

return Remotes
