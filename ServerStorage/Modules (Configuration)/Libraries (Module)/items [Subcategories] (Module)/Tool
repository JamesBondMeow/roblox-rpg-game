--[[
	ToolLib
	
	ToolLib is an item library that houses code that can be ran on the server relating
	to Tools, such as ToolLib:Give(Player, Tool (ContentLib.Tool[...]))
]]

--> Services
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local ServerStorage = game:GetService("ServerStorage")
local Players = game:GetService("Players")

--> References
local PlayerData = ReplicatedStorage:WaitForChild("PlayerData")

--> Dependencies
local ContentLibrary = require(ReplicatedStorage.Modules.Shared.ContentLibrary)

local CreateValue = require(ServerStorage.Modules.Server.createValue)
local RemoveValue = require(ServerStorage.Modules.Server.removeValue)

local GameConfig = require(ReplicatedStorage.GameConfig)

--> Variables
local Library = script.Name
local ToolLib = {}

--------------------------------------------------------------------------------

function ToolLib:Give(Player: Player, Tool, DontSave, ShopBought, Amount)
	local pData = PlayerData:WaitForChild(Player.UserId, 5)

	local isItem = typeof(Tool) == "table" 
	if not isItem then
		warn(`Item {Library} --> {tostring(Tool) or "nil"} doesn't exist as a table, try using ContentLibrary.`)
		return
	end

	if pData then
		local Found = pData.Items[Library]:FindFirstChild(Tool.Name)

		local IsStackable = GameConfig.CanItemsStack or GameConfig.Categories[Library].IsStackable
		local CanGive = ((not Found) or IsStackable)

		local CanBuyMultiple = ShopBought == "Force" or (ShopBought and (not Tool.Config.Cost[4]) and IsStackable)
		if CanGive or CanBuyMultiple then
			CreateValue(pData, Tool, DontSave, Amount, Library)

			-- Parse the compound name so the server natively stamps the attributes on the physical tool
			local split = string.split(Tool.Name, "|")
			local baseName = split[1]
			local enchants = {}
			for i = 2, #split do table.insert(enchants, split[i]) end
			local enchantAttr = #enchants > 0 and table.concat(enchants, ",") or nil

			-- Helper to ensure we don't accidentally duplicate the exact enchanted variant
			local function checkHasPhysical(container)
				if not container then return false end
				for _, t in ipairs(container:GetChildren()) do
					local tAttr = t:GetAttribute("Enchantments")
					if tAttr == "" then tAttr = nil end

					if t.Name == baseName and tAttr == enchantAttr then
						return true
					end
				end
				return false
			end

			local StarterGear = Player:FindFirstChild("StarterGear")
			if StarterGear and not checkHasPhysical(StarterGear) then
				local clone = Tool.Instance:Clone()
				clone.Name = baseName -- Safe name for native equipping
				if enchantAttr then clone:SetAttribute("Enchantments", enchantAttr) end
				clone.Parent = StarterGear
			end

			local Backpack = Player:WaitForChild("Backpack")
			local hasInBackpack = checkHasPhysical(Backpack)
			local hasInCharacter = checkHasPhysical(Player.Character)

			if Backpack and not (hasInBackpack or hasInCharacter) then
				local clone = Tool.Instance:Clone()
				clone.Name = baseName -- Safe name for native equipping
				if enchantAttr then clone:SetAttribute("Enchantments", enchantAttr) end
				clone.Parent = Backpack
			end

			return true
		end
	else
		warn(("pData for Player '%s' doesn't exist! Did they leave?"):format(Player.Name))
	end
end

function ToolLib:Trash(Player: Player, Tool, Amount)
	local pData = PlayerData:WaitForChild(Player.UserId, 5)

	if pData then
		RemoveValue(pData, Tool, Amount, Library)

		local CompletelyRemoved = not pData.Items[Library]:FindFirstChild(Tool.Name)
		if CompletelyRemoved then

			-- Ensure the server deletes the exact enchanted variant if called here
			local split = string.split(Tool.Name, "|")
			local baseName = split[1]
			local enchants = {}
			for i = 2, #split do table.insert(enchants, split[i]) end
			local enchantAttr = #enchants > 0 and table.concat(enchants, ",") or nil

			local function removeMatches(container)
				if not container then return end
				for _, t in ipairs(container:GetChildren()) do
					local tAttr = t:GetAttribute("Enchantments")
					if tAttr == "" then tAttr = nil end

					if t.Name == baseName and tAttr == enchantAttr then
						t:Destroy()
					end
				end
			end

			removeMatches(Player:FindFirstChild("StarterGear"))
			removeMatches(Player:FindFirstChild("Backpack"))
			if Player.Character then
				removeMatches(Player.Character)
			end
		end
	else
		warn(("pData for Player '%s' doesn't exist! Did they leave?"):format(Player.Name))
	end
end

return ToolLib
