	-- HELPERS

	local function isSlotInHotbar(Slot): boolean
		return Slot.HotbarNumber ~= nil
	end

	local function isSlotInInventory(Slot): boolean
		return not isSlotInHotbar(Slot)
	end

	local function GetSlotKey(ItemInstance)
		if not ItemInstance then return "" end
		local enchantAttr = typeof(ItemInstance) == "Instance" and ItemInstance:GetAttribute("Enchantments")

		if enchantAttr and enchantAttr ~= "" then
			-- Split, sort alphabetically (so Flame|Lifesteal is the same as Lifesteal|Flame), and format
			local encTable = string.split(enchantAttr, ",")
			table.sort(encTable)
			return ItemInstance.Name .. "|" .. table.concat(encTable, "|")
		end

		return ItemInstance.Name
	end

