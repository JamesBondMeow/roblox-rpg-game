--> Services
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local ServerStorage = game:GetService("ServerStorage")

--> References
local PlayerData = ReplicatedStorage:WaitForChild("PlayerData")

--> Dependencies
local ContentLibrary = require(ReplicatedStorage.Modules.Shared.ContentLibrary)
local CountTotalCopies = require(ReplicatedStorage.Modules.Shared.countTotalCopies)
local GetMaxCraftable = require(ReplicatedStorage.Modules.Shared.getMaxCraftable)
local GameConfig = require(ReplicatedStorage.GameConfig)
local GiveItemWithAmount = require(ServerStorage.Modules.Server.giveItemWithAmount)
local RemoveItemWithAmount = require(ServerStorage.Modules.Server.removeItemWithAmount)

--> Variables
local Remotes = {}
local RNG = Random.new()

--------------------------------------------------------------------------------

if not GameConfig.EnabledFeatures.Crafting then
	return {}
end

-- Server-side calculation, now accepts a table of essence names
local function calculateSuccessChance(player, itemData, amount, essencesTable)
	local baseChance = itemData.BaseSuccessChance or 1
	local decreasePerItem = itemData.ChanceDecreasePerItem or 0

	local totalEssenceIncrease = 0
	if essencesTable then
		for _, essenceName in ipairs(essencesTable) do
			if essenceName and essenceName ~= "" then
				local essenceItem = ContentLibrary.Material[essenceName]
				if essenceItem and essenceItem.Config.SuccessChanceIncrease then
					totalEssenceIncrease += essenceItem.Config.SuccessChanceIncrease
				end
			end
		end
	end

	local calculationAmount = math.max(amount, 1)
	local quantityPenalty = (calculationAmount - 1) * decreasePerItem

	local finalChance = math.clamp(baseChance + totalEssenceIncrease - quantityPenalty, 0, 1)
	return finalChance
end


-- Accepts a table of applied essence names
function Remotes:OnEvent(Player, Data, Smithery, Amount, AppliedEssences) 
	if not Data or not Smithery then return end
	if typeof(Data) ~= "table" then return end
	if AppliedEssences and typeof(AppliedEssences) ~= "table" then return false, "Invalid essence data" end

	local Config = Smithery:FindFirstChild("Config") and require(Smithery.Config)
	if not Config or not Config.Smithery then
		return false, "Smithery does not exist"
	end

	local ItemData = nil
	for _, NewData in Config.Smithery do
		if NewData.Item[1] == Data[1] and NewData.Item[2] == Data[2] then
			ItemData = NewData
			break
		end
	end

	local InvalidNumber = math.floor(Amount) ~= Amount
		or Amount ~= Amount
		or typeof(Amount) ~= "number"
		or math.abs(Amount) ~= Amount

	if InvalidNumber or Amount < 1 then
		return false, "Invalid amount"
	end

	if ItemData then
		local pData = PlayerData:FindFirstChild(Player.UserId)
		local ContentItem = ContentLibrary[Data[1]] and ContentLibrary[Data[1]][Data[2]]
		if not pData or not ContentItem then
			return false, "Incorrect data was passed through"
		end

		Amount = math.min(Amount, GameConfig.Categories[ContentItem.Type].BulkBuyMax)

		if not ItemData.CraftMultiple and (CountTotalCopies(ContentItem, Player) >= 1 or Amount > 1) then
			return false, "You already own this item"
		end

		local MaxPossibleCrafts = GetMaxCraftable(ItemData, Player)
		if Amount > MaxPossibleCrafts then
			return false, "You don't have enough materials"
		end

		-- Check if essence is required but none were applied
		local useChanceCrafting = Config.ChanceCrafting and ItemData.BaseSuccessChance
		if useChanceCrafting and ItemData.RequiresEssence and (#AppliedEssences == 0) then
			return false, "This recipe requires essence to craft"
		end

		-- Count required essences and check if player has enough
		local requiredEssences = {}
		if AppliedEssences then
			for _, essenceName in ipairs(AppliedEssences) do
				requiredEssences[essenceName] = (requiredEssences[essenceName] or 0) + 1
			end
		end

		for essenceName, requiredCount in pairs(requiredEssences) do
			local essenceItem = ContentLibrary.Material[essenceName]
			if not essenceItem or CountTotalCopies(essenceItem, Player) < requiredCount * Amount then
				return false, "You do not have enough " .. essenceName
			end
		end

		-- Consume materials FIRST
		local Stats = pData:FindFirstChild("Stats")
		for Category, Items in ItemData.Recipe do
			local IsStatistics = Category == "Statistics"
			if IsStatistics then
				for _, Stat in Items do
					local Statistic = Stats:FindFirstChild(Stat[1])
					Statistic.Value -= (Stat[2] * Amount)
				end
			elseif not IsStatistics then
				for _, Item in Items do
					local recipeItem = ContentLibrary[Category][Item[1]]
					RemoveItemWithAmount(Player, recipeItem.Config.Type, Item[1], (Item[2] * Amount))
				end
			end
		end

		-- Consume Applied Essences
		for essenceName, requiredCount in pairs(requiredEssences) do
			local essenceItem = ContentLibrary.Material[essenceName]
			RemoveItemWithAmount(Player, essenceItem.Config.Type, essenceName, requiredCount * Amount)
		end

		-- Perform the chance roll if applicable
		if useChanceCrafting then
			local successChance = calculateSuccessChance(Player, ItemData, Amount, AppliedEssences)
			local roll = RNG:NextNumber()

			if roll <= successChance then
				-- SUCCESS!
				GiveItemWithAmount(Player, ContentItem.Config.Type, ContentItem.Name, Amount)
				return true, Amount
			else
				-- FAILURE!
				return false, "Crafting failed! Materials and essence were lost."
			end
		else
			-- No chance crafting
			GiveItemWithAmount(Player, ContentItem.Config.Type, ContentItem.Name, Amount)
			return true, Amount
		end
	else
		return false, "Item does not exist in this smithery"
	end
end

return Remotes
