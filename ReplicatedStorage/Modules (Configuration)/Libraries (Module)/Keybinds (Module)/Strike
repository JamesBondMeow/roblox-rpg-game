-- [CLIENT]
-- Strike Ability

local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local Debris = game:GetService("Debris")
local SFX = require(ReplicatedStorage.Modules.Shared.SFX)

local Keybind = {}

function Keybind:Validate(Player)
	local Character = Player.Character
	local humanoid = Character and Character:FindFirstChildOfClass("Humanoid")
	local manaFolder = humanoid and humanoid:FindFirstChild("Mana")
	local manaValue = manaFolder and manaFolder:FindFirstChild("Mana")
	local currentMana = manaValue and manaValue:GetAttribute("Default") or 0

	return currentMana >= 20
end

function Keybind:OnActivated(Player)
	if not self:Validate(Player) then return end

	local Character = Player.Character
	local humanoid = Character:FindFirstChildOfClass("Humanoid")
	local rootPart = Character:FindFirstChild("HumanoidRootPart")

	local Tool = Character:FindFirstChildWhichIsA("Tool")
	if not Tool then return end

	local strikeAnim = Instance.new("Animation")
	strikeAnim.AnimationId = "rbxassetid://121613611346240" 
	local track = humanoid:LoadAnimation(strikeAnim)
	track:Play()

	-- Sound for the strike impact
	SFX:Play3D("rbxassetid://12222216", rootPart)
	Debris:AddItem(strikeAnim, 0.5)
end

function Keybind:OnLetGo(Player) end

return Keybind
