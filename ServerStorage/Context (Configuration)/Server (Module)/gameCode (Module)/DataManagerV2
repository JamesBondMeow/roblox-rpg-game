local PlayerData = Instance.new("Folder")
PlayerData.Name = "PlayerData"
PlayerData.Parent = ReplicatedStorage

local function ClampStat(ValueObject: IntValue, Min: number?, Max: number?)
	ValueObject.Changed:Connect(function()
		ValueObject.Value = math.clamp(ValueObject.Value, Min or -math.huge, Max or math.huge)
	end)
end

local function CreateStat(ClassName: string, Name: string, DefaultValue, ClampInfo)
	local Stat = Instance.new(ClassName)
	Stat.Name = Name
	Stat.Value = (DefaultValue or 0)
	if ClampInfo and (Stat:IsA("NumberValue") or Stat:IsA("IntValue")) then
		ClampStat(Stat, unpack(ClampInfo))
	end
	return Stat
end

local function CreateDataFolder(Player): Instance
	local oldData = PlayerData:FindFirstChild(Player.UserId)
	if oldData then
		oldData:Destroy()
	end

	local pData = Instance.new("Folder")
	pData.Name = Player.UserId

	---- Stats
	local Stats = Instance.new("Folder")
	Stats.Name = "Stats"
	Stats.Parent = pData

	for StatName, Data in GameConfig.Leaderstats do
		local Constraint = Data.Constraint or {0}
		local Max = Constraint[2]
		if Max and Max == true then
			Constraint[2] = GameConfig["Max" .. StatName]
		end
		local Stat = CreateStat("NumberValue", StatName, Constraint[1], Constraint)
		Stat.Parent = Stats
	end

	---- Items
	local Items = Instance.new("Folder")
	Items.Name = "Items"
	Items.Parent = pData

	for ItemType in GameConfig.Categories do
		local Folder = Instance.new("Folder")
		Folder.Name = ItemType
		Folder.Parent = Items
	end

	---- Attributes
	local Attributes = Instance.new("Folder")
	Attributes.Name = "Attributes"
	Attributes.Parent = pData
	for Attribute in GameConfig.Attributes do
		local Value = Instance.new("NumberValue")
		Value.Name = Attribute
		Value.Parent = Attributes

		if AttributeFunctions[Attribute] then
			local function UpdateAttribute()
				AttributeFunctions[Attribute](nil, Player, Attributes)
			end
			Player.CharacterAdded:Connect(function() task.defer(UpdateAttribute) end)
			task.defer(UpdateAttribute)
			Value.Changed:Connect(UpdateAttribute)
		end
	end

	local Points = Instance.new("NumberValue")
	Points.Name = "Points"
	Points.Parent = pData

	---- Chest cooldowns
	local ChestCooldowns = Instance.new("Folder")
	ChestCooldowns.Name = "Chests"
	ChestCooldowns.Parent = pData

	for _, Chest in CollectionService:GetTagged("Chest") do
		local Config = Chest:FindFirstChild("Config") and require(Chest.Config)
		if Config and Config.Name then
			if ChestCooldowns:FindFirstChild(Config.Name) then continue end
			local Value = Instance.new("NumberValue")
			Value.Name = Config.Name
			Value.Parent = ChestCooldowns
		end
	end

	---- Quest handling
	local Quests = Instance.new("Folder")
	Quests.Name = "Quests"
	Quests.Parent = pData

	local CompletedQuests = Instance.new("Folder")
	CompletedQuests.Name = "Completed"
	CompletedQuests.Parent = Quests

	local ActiveQuests = Instance.new("Folder")
	ActiveQuests.Name = "Active"
	ActiveQuests.Parent = Quests

	---- Mob Kills
	local MobKills = Instance.new("Folder")
	MobKills.Name = "MobKills"
	MobKills.Parent = pData

	---- NPC interactions
	local Interactions = Instance.new("Folder")
	Interactions.Name = "Interactions"
	Interactions.Parent = pData

	---- Accessory Slots
	local EquippedSlots = Instance.new("Folder")
	EquippedSlots.Name = "EquippedSlots"
	for Iteration = 1, GameConfig.EquippedAccessoryMax do
		local Slot = CreateStat("StringValue", Iteration, "")
		Slot.Parent = EquippedSlots
	end
	EquippedSlots.Parent = pData

	---- Orb Data
	local EquippedOrbs = Instance.new("Folder")
	EquippedOrbs.Name = "EquippedOrbs"
	for Iteration = 1, GameConfig.EquippedOrbMax do
		local Slot = CreateStat("StringValue", Iteration, "")
		Slot.Parent = EquippedOrbs
	end
	EquippedOrbs.Parent = pData

	---- Awarded Gamepasses Flag Storage
	local AwardedGamepasses = Instance.new("Folder")
	AwardedGamepasses.Name = "AwardedGamepasses"
	AwardedGamepasses.Parent = pData
	
	---- Opened Doors
	local OpenedDoors = Instance.new("Folder")
	OpenedDoors.Name = "OpenedDoors"
	OpenedDoors.Parent = pData

	---- Active Armor (Split into 3 slots)
	local ActiveArmor = Instance.new("Folder")
	ActiveArmor.Name = "ActiveArmor"
	ActiveArmor.Parent = pData

	-- Create slots for each type
	CreateStat("StringValue", "Helmet", "").Parent = ActiveArmor
	CreateStat("StringValue", "Pauldron", "").Parent = ActiveArmor
	CreateStat("StringValue", "Chestplate", "").Parent = ActiveArmor

	---- Hotbar & Misc
	local Hotbar = Instance.new("Folder")
	Hotbar.Name = "Hotbar"
	Hotbar.Parent = pData

	for n = 1, 9 do
		local ValueObject = CreateStat("StringValue", tostring(n), "")
		ValueObject.Parent = Hotbar
	end

	local SpinTime = CreateStat("NumberValue", "SpinTime", 0)
	SpinTime.Parent = pData

	local Spins = CreateStat("NumberValue", "Spins", 1)
	Spins.Parent = pData

	if GameConfig.SaveCurrentLocation then
		task.spawn(function()
			while true do
				local SavedCFrame = nil :: CFrame
				local Character = Player.Character
				local Humanoid = Character and Character:FindFirstChildWhichIsA("Humanoid") :: Humanoid
				if Humanoid and Humanoid.Health > 0 then
					SavedCFrame = Character:GetPivot()
				end
				AttributeModule:SetAttribute(Player, "SavedCFrame", SavedCFrame)
				task.wait(GameConfig.SavedPositionRefresh)
			end
		end)
	end

	return pData
end

local function UnloadTools(ConvertedToolTable, Folder, Player, AssetType)
	local StarterGear = Player:WaitForChild("StarterGear")
	local Backpack = Player:WaitForChild("Backpack")

	for CompoundName, Value in ConvertedToolTable do
		if Value <= 0 then continue end

		local SplitName = string.split(tostring(CompoundName), "|")
		local BaseName = SplitName[1]

		local Enchants = {}
		for i = 2, #SplitName do
			table.insert(Enchants, SplitName[i])
		end
		-- Join them back together with a comma for the attribute
		local EnchantAttribute = #Enchants > 0 and table.concat(Enchants, ",") or nil

		local Library = ContentLibrary[AssetType] or {}
		local ToolData = Library[BaseName]

		if ToolData then
			-- Accurately count existing physical tools based on BOTH their name and their exact enchantments
			local function getPhysicalCount(container)
				local count = 0
				if container then
					for _, t in ipairs(container:GetChildren()) do
						local tAttr = t:GetAttribute("Enchantments")
						if tAttr == "" then tAttr = nil end
						if t.Name == BaseName and tAttr == EnchantAttribute then
							count += 1
						end
					end
				end
				return count
			end

			local targetCount = Value

			-- Give to StarterGear so it persists through death
			local sgCount = getPhysicalCount(StarterGear)
			for i = 1, targetCount - sgCount do
				local SG_Clone = ToolData.Instance:Clone()
				SG_Clone.Name = BaseName -- Keep safe name for equipping
				if EnchantAttribute then SG_Clone:SetAttribute("Enchantments", EnchantAttribute) end
				SG_Clone.Parent = StarterGear
			end

			-- Give to Backpack for immediate use
			local bpCount = getPhysicalCount(Backpack)
			local charCount = getPhysicalCount(Player.Character)
			for i = 1, targetCount - (bpCount + charCount) do
				local BP_Clone = ToolData.Instance:Clone()
				BP_Clone.Name = BaseName -- Keep safe name for equipping
				if EnchantAttribute then BP_Clone:SetAttribute("Enchantments", EnchantAttribute) end
				BP_Clone.Parent = Backpack
			end

			local Stat = CreateStat("NumberValue", tostring(CompoundName))
			Stat.Parent = Folder
			Stat.Value = Value
		end
	end
end

-- Unloads loaded user data table into their game session
local function UnloadData(Player: Player, Data: any, pData: Instance)
	local RejoinTime = tick() - (Data.LastJoin or tick())

	-- Restore Product Ownership (Deals/Gamepasses)
	-- We force set the Roblox Attribute to ensure Client logic sees it immediately
	if Data.ProductOwnership then
		print("DataManager: Loading ProductOwnership for", Player.Name, Data.ProductOwnership)
		for assetId, owned in pairs(Data.ProductOwnership) do
			if owned then
				local idStr = tostring(assetId)
				AttributeModule:SetAttribute(Player, idStr, true)
				-- Also set directly on Player instance for client replication
				Player:SetAttribute(idStr, true)
			end
		end
	else
		print("DataManager: No ProductOwnership data found for", Player.Name)
	end

	-- Restore First Join Time
	if Data.FirstJoinTime then
		AttributeModule:SetAttribute(Player, "FirstJoinTime", Data.FirstJoinTime)
		Player:SetAttribute("FirstJoinTime", Data.FirstJoinTime)
	else
		local now = os.time()
		AttributeModule:SetAttribute(Player, "FirstJoinTime", now)
		Player:SetAttribute("FirstJoinTime", now)
	end

	-- Stats
	local Stats = pData:FindFirstChild("Stats")
	for StatName, StatValue in Data.Stats do
		local Stat = Stats:FindFirstChild(StatName)
		if Stat then Stat.Value = StatValue end
	end

	-- Items
	local Items = pData:FindFirstChild("Items")
	for ItemType, NewData in pairs(GameConfig.Categories) do
		local ConvertedToolTable = (Data.Converted and Data.Items[ItemType]) or {}
		if not Data.Converted then 
			for Index, Value in pairs(Data.Items[ItemType] or {}) do
				if typeof(Index) == "number" then
					ConvertedToolTable[Value] = (ConvertedToolTable[Value] and ConvertedToolTable[Value] + 1) or 1
				else
					ConvertedToolTable[Index] = Value
				end
			end
		end

		local isATool = NewData.IsATool
		if isATool then
			UnloadTools(ConvertedToolTable, Items[ItemType], Player, ItemType)
		elseif not isATool then
			local Folder = Items:FindFirstChild(ItemType)
			for CompoundName, Value in ConvertedToolTable do
				if Value <= 0 then continue end

				-- Safely split and read the BaseName
				local SplitName = string.split(tostring(CompoundName), "|")
				local BaseName = SplitName[1]

				local Item = ContentLibrary[ItemType][BaseName]
				if Item then 
					local Stat = CreateStat("NumberValue", tostring(CompoundName))
					Stat.Parent = Folder
					Stat.Value = Value 
				end
			end
		end
	end

	-- Attributes, Points, Chests, Quests, MobKills, Statuses, Interactions, Accessories, Orbs, Gamepasses
	local Attributes = pData:FindFirstChild("Attributes")
	if Attributes and Data.Attributes then
		for _, Atribute in Attributes:GetChildren() do Atribute.Value = Data.Attributes[Atribute.Name] or 0 end
	end

	local Points = pData:FindFirstChild("Points")
	if Points and Data.Points then Points.Value = Data.Points end

	local ChestCooldowns = pData:FindFirstChild("Chests")
	if ChestCooldowns and Data.ChestCooldowns then
		for Name, Cooldown in Data.ChestCooldowns do
			local MaxCooldown = math.huge
			for _, Chest in CollectionService:GetTagged("Chest") do
				local Config = Chest:FindFirstChild("Config") and require(Chest.Config)
				if Config and Config.Name == Name then
					MaxCooldown = (Config.Cooldown.Days * 86400) + (Config.Cooldown.Hours * 3600) + (Config.Cooldown.Minutes * 60) + Config.Cooldown.Seconds
				end
			end
			local Value = ChestCooldowns:FindFirstChild(Name)
			if Value and Value.Value < 1e9 then Value.Value = math.clamp(Cooldown - RejoinTime, 0, MaxCooldown) end
		end
	end

	local Quests = pData:FindFirstChild("Quests")
	if Quests and Data.Quests then
		for _, Name in Data.Quests.Completed do
			local Value = Instance.new("BoolValue")
			Value.Parent = Quests.Completed
			Value.Name = Name
			Value.Value = true
		end
		for Name, Data in Data.Quests.Active do
			local Folder = Instance.new("Folder")
			Folder.Name = Name
			for NewName, NewData in Data.Data or Data do
				local NewFolder = Instance.new("Folder")
				NewFolder.Name = NewName
				Folder:SetAttribute("Start", Data.Start or os.time())
				for ValueName, Value in NewData do
					if typeof(Value) == "boolean" then
						local Boolean = Instance.new("BoolValue")
						Boolean.Parent = NewFolder
						Boolean.Name = ValueName
						Boolean.Value = Value
					elseif typeof(Value) == "number" then
						local Number = Instance.new("NumberValue")
						Number.Parent = NewFolder
						Number.Name = ValueName
						Number.Value = Value
					end
				end
				NewFolder.Parent = Folder
			end
			Folder.Parent = Quests.Active
		end
	end

	local MobKillsFolder = pData:FindFirstChild("MobKills")
	if MobKillsFolder and Data.MobKills then
		for mobName, killCount in pairs(Data.MobKills) do
			local Stat = CreateStat("NumberValue", mobName, killCount)
			Stat.Parent = MobKillsFolder
		end
	end

	task.spawn(function()
		local Statuses = Player:WaitForChild("Statuses")
		for Name, Data in (Data.Statuses or {}) do
			local Status = Statuses:WaitForChild(Name)
			for NewName, Value in Data do Status:SetAttribute(NewName, Value) end
		end
	end)

	local EquippedSlots = pData:FindFirstChild("EquippedSlots")
	if EquippedSlots and Data.EquippedSlots then
		for Index, Name in Data.EquippedSlots do
			local Value = EquippedSlots:FindFirstChild(tostring(Index))
			if Value then Value.Value = Name end
		end
	end

	local EquippedOrbs = pData:FindFirstChild("EquippedOrbs")
	if EquippedOrbs and Data.EquippedOrbs then
		for Index, Name in Data.EquippedOrbs do
			local Value = EquippedOrbs:FindFirstChild(tostring(Index))
			if Value then Value.Value = Name end
		end
	end

	local AwardedGamepassesFolder = pData:FindFirstChild("AwardedGamepasses")
	if AwardedGamepassesFolder and Data.AwardedGamepasses then
		for _, assetId in ipairs(Data.AwardedGamepasses) do
			local flagValue = Instance.new("BoolValue")
			flagValue.Name = "Awarded_GP_" .. assetId
			flagValue.Value = true
			flagValue.Parent = AwardedGamepassesFolder
		end
	end
	
	-- Load Opened Doors
	local OpenedDoors = pData:FindFirstChild("OpenedDoors")
	if OpenedDoors and Data.OpenedDoors then
		for _, Name in ipairs(Data.OpenedDoors) do
			local Value = Instance.new("BoolValue")
			Value.Name = Name
			Value.Value = true
			Value.Parent = OpenedDoors
		end
	end

	local Interactions = pData:FindFirstChild("Interactions")
	if Interactions and Data.Interactions then
		for Name, _Value in Data.Interactions do
			local Value = Instance.new("NumberValue")
			Value.Parent = Interactions
			Value.Name = Name
			Value.Value = _Value
		end
	end

	-- Active Armor
	local ActiveArmorFolder = pData:FindFirstChild("ActiveArmor")
	if ActiveArmorFolder and Data.ActiveArmor then
		if typeof(Data.ActiveArmor) == "table" then
			ActiveArmorFolder.Helmet.Value = Data.ActiveArmor.Helmet or ""
			ActiveArmorFolder.Pauldron.Value = Data.ActiveArmor.Pauldron or ""
			ActiveArmorFolder.Chestplate.Value = Data.ActiveArmor.Chestplate or ""
		end
	end

	local HotbarFolder = pData:FindFirstChild("Hotbar")
	for SlotNumber, ItemName in Data.Hotbar do
		HotbarFolder:FindFirstChild(SlotNumber).Value = ItemName
	end

	local SpinTime = pData:FindFirstChild("SpinTime")
	if SpinTime then SpinTime.Value = Data.SpinTime or 0 end

	local Spins = pData:FindFirstChild("Spins")
	if Spins then Spins.Value = Data.Spins or 1 end
	
	if Data.RespawnPoint then
		AttributeModule:SetAttribute(Player, "RespawnPoint", Data.RespawnPoint)
		Player:SetAttribute("RespawnPoint", Data.RespawnPoint)
	end

	if Data.SavedCFrame then
		task.spawn(function()
			local Character = Player.Character or Player.CharacterAdded:Wait()
			if not Player:HasAppearanceLoaded() then Player.CharacterAppearanceLoaded:Wait() end
			task.wait(0.5)
			Character:PivotTo(CFrame.new(Data.SavedCFrame.X, Data.SavedCFrame.Y, Data.SavedCFrame.Z))
		end)
	end
end

local function WaitForRequestBudget(RequestType)
	local CurrentBudget = DataStoreService:GetRequestBudgetForRequestType(RequestType)
	while CurrentBudget < 1 do
		CurrentBudget = DataStoreService:GetRequestBudgetForRequestType(RequestType)
		task.wait(5)
	end
end

-- Attempt to save user data.
local function SaveData(Player: Player): boolean
	if not Player:GetAttribute("DataLoaded") then return false end

	local pData = PlayerData:FindFirstChild(Player.UserId)
	local StarterGear = Player:FindFirstChild("StarterGear")
	if not pData or not StarterGear then return false end

	if SameKeyCooldown[Player.UserId] then
		repeat task.wait() until not SameKeyCooldown[Player.UserId]
	end
	SameKeyCooldown[Player.UserId] = true
	task.delay(GameConfig.PreLoadTime, function() SameKeyCooldown[Player.UserId] = nil end)
	
	local DataToSave = {}
	DataToSave.Stats = {}
	DataToSave.Items = {}
	DataToSave.ProductOwnership = {}
	DataToSave.Attributes = {}
	DataToSave.ChestCooldowns = {}
	DataToSave.Statuses = {}
	DataToSave.Quests = { Completed = {}, Active = {} }
	DataToSave.Interactions = {}
	DataToSave.OpenedDoors = {}
	DataToSave.EquippedSlots = {}
	for Iteration = 1, GameConfig.EquippedAccessoryMax do DataToSave.EquippedSlots[Iteration] = "" end
	DataToSave.EquippedOrbs = {}
	for Iteration = 1, GameConfig.EquippedOrbMax do DataToSave.EquippedOrbs[Iteration] = "" end
	DataToSave.AwardedGamepasses = {}
	DataToSave.RespawnPoint = Player:GetAttribute("RespawnPoint") or AttributeModule:GetAttribute(Player, "RespawnPoint")

	-- Save Product Ownership
	-- We check Player:GetAttribute to ensure we catch anything the Client sees or ProductLib sets
	local savedCount = 0
	for _, product in ipairs(GameConfig.Products) do
		if product.Type == "Deal" or product.Type == "Gamepass" and product.AssetID ~= 0 then
			local idStr = tostring(product.AssetID)
			-- Check both AttributeModule and Roblox Attribute
			local rawAttr = Player:GetAttribute(idStr)
			local modAttr = AttributeModule:GetAttribute(Player, idStr)

			if rawAttr == true or modAttr == true then
				DataToSave.ProductOwnership[idStr] = true
				savedCount += 1
			end
		end
	end
	print("DataManager: Saving", savedCount, "owned products for", Player.Name)

	-- Save First Join Time
	DataToSave.FirstJoinTime = Player:GetAttribute("FirstJoinTime") or AttributeModule:GetAttribute(Player, "FirstJoinTime")

	local AwardedGamepassesFolder = pData:FindFirstChild("AwardedGamepasses")
	if AwardedGamepassesFolder then
		for _, flagValue in ipairs(AwardedGamepassesFolder:GetChildren()) do
			local assetId = flagValue.Name:match("Awarded_GP_(%d+)")
			if assetId then table.insert(DataToSave.AwardedGamepasses, tonumber(assetId)) end
		end
	end

	local Stats = pData:FindFirstChild("Stats")
	for _, ValueObject in Stats:GetChildren() do DataToSave.Stats[ValueObject.Name] = ValueObject.Value end

	local Items = pData:FindFirstChild("Items")
	local function CollectiveSave(AssetType)
		local Folder = Items:FindFirstChild(AssetType)
		if not Folder then return end
		for _, ValueObject in Folder:GetChildren() do
			local DontSave = ValueObject:GetAttribute("DontSave")
			if not ValueObject:IsA("NumberValue") and DontSave then continue end

			-- Only check ContentLibrary for the BaseName
			local BaseName = string.split(ValueObject.Name, "|")[1]
			local Library = ContentLibrary[AssetType] or {}

			if Library[BaseName] then
				if ValueObject:IsA("NumberValue") or ValueObject:IsA("IntValue") then
					DataToSave.Items[AssetType][ValueObject.Name] = ValueObject.Value - (DontSave or 0)
				else
					table.insert(DataToSave.Items[AssetType], ValueObject.Name)
				end
			end
		end
	end

	for ItemType, Data in GameConfig.Categories do
		DataToSave.Items[ItemType] = {}
		CollectiveSave(ItemType)
	end

	for _, Attribute in pData.Attributes:GetChildren() do DataToSave.Attributes[Attribute.Name] = Attribute.Value end
	DataToSave.Points = pData.Points.Value

	for _, Cooldown in pData.Chests:GetChildren() do DataToSave.ChestCooldowns[Cooldown.Name] = Cooldown.Value end

	for _, Value in pData.Quests.Completed:GetChildren() do table.insert(DataToSave.Quests.Completed, Value.Name) end
	for _, Folder in pData.Quests.Active:GetChildren() do
		local SaveTable = {}
		local QuestData = QuestLibrary[Folder.Name]
		if not QuestData then continue end
		for Name, Data in QuestData.Requirements do
			SaveTable[Name] = {}
			for NewName, Value in Data do
				if typeof(Value) == "function" then SaveTable[Name][NewName] = false else SaveTable[Name][Value[1]] = 0 end
			end
		end 
		for _, NewFolder in Folder:GetChildren() do
			for _, Value in NewFolder:GetChildren() do SaveTable[NewFolder.Name][Value.Name] = Value.Value end
		end
		DataToSave.Quests.Active[Folder.Name] = { Data = SaveTable, Start = Folder:GetAttribute("Start") or os.time() }
	end

	DataToSave.MobKills = {}
	local MobKillsFolder = pData:FindFirstChild("MobKills")
	if MobKillsFolder then
		for _, killValue in ipairs(MobKillsFolder:GetChildren()) do
			if killValue:IsA("NumberValue") then DataToSave.MobKills[killValue.Name] = killValue.Value end
		end
	end

	local Statuses = Player:FindFirstChild("Statuses")
	if Statuses then
		for _, Status in Statuses:GetChildren() do
			DataToSave.Statuses[Status.Name] = { Duration = Status:GetAttribute("Duration"), Boost = Status:GetAttribute("Boost"), Addition = Status:GetAttribute("Addition") }
		end
	end

	local Interactions = pData:FindFirstChild("Interactions")
	if Interactions then
		for _, Value in Interactions:GetChildren() do DataToSave.Interactions[Value.Name] = Value.Value end
	end
	
	-- Save Opened Doors
	local OpenedDoors = pData:FindFirstChild("OpenedDoors")
	if OpenedDoors then
		for _, Value in OpenedDoors:GetChildren() do table.insert(DataToSave.OpenedDoors, Value.Name) end
	end

	for Index in DataToSave.EquippedSlots do
		local Value = pData.EquippedSlots:FindFirstChild(tostring(Index))
		if Value then DataToSave.EquippedSlots[Index] = Value.Value end
	end

	for Index in DataToSave.EquippedOrbs do
		local Value = pData.EquippedOrbs:FindFirstChild(tostring(Index))
		if Value then DataToSave.EquippedOrbs[Index] = Value.Value end
	end

	local SavedCFrame = AttributeModule:GetAttribute(Player, "SavedCFrame")
	if GameConfig.SaveCurrentLocation and SavedCFrame and not AttributeModule:GetAttribute(Player, "DontSaveCFrame") then
		DataToSave.SavedCFrame = { X = SavedCFrame.Position.X, Y = SavedCFrame.Position.Y, Z = SavedCFrame.Position.Z }
	end

	local ActiveArmorFolder = pData:FindFirstChild("ActiveArmor")
	DataToSave.ActiveArmor = {
		Helmet = ActiveArmorFolder.Helmet.Value,
		Pauldron = ActiveArmorFolder.Pauldron.Value,
		Chestplate = ActiveArmorFolder.Chestplate.Value
	}

	DataToSave.Hotbar = {}
	for _, ValueObject in pData.Hotbar:GetChildren() do DataToSave.Hotbar[ValueObject.Name] = ValueObject.Value end

	DataToSave.SpinTime = pData.SpinTime.Value
	DataToSave.Spins = pData.Spins.Value
	DataToSave.LastJoin = tick()
	DataToSave.Converted = true

	local Success = nil :: boolean
	local Response = nil :: any

	repeat
		WaitForRequestBudget(Enum.DataStoreRequestType.SetIncrementAsync)
		Success, Response = pcall(function()
			return UserData:UpdateAsync("user/".. Player.UserId, function() return DataToSave end)
		end)
	until Success

	print(`DataManager: User {Player.Name}'s data saved successfully.`)
	return Success
end

local function LoadData(Player: Player): (boolean, any)
	local Success = nil :: boolean
	local Response = nil :: any
	repeat
		Success, Response = pcall(function()
			local RequestedData = nil
			UserData:UpdateAsync("user/".. Player.UserId, function(Data) RequestedData = Data end)
			return RequestedData
		end)
		if (not Success) or (Response == "wait") then task.wait(4) end
	until Success
	if Response then print(`DataManager: User {Player.Name}'s data loaded.`) else print(`DataManager: User {Player.Name} new load.`) end
	return Success, Response
end

local function OnPlayerAdded(Player: Player)
	local Success, Data = LoadData(Player)
	if not Success then
		CollectionService:AddTag(Player, "DataFailed")
		Player:Kick("Data unable to load.")
		return
	end
	
	local pData = CreateDataFolder(Player)
	if Data then 
		UnloadData(Player, Data, pData) 
	else
		-- New Player Setup
		local now = os.time()
		AttributeModule:SetAttribute(Player, "FirstJoinTime", now)
		Player:SetAttribute("FirstJoinTime", now)
	end
	
	pData.Parent = PlayerData
	Player:SetAttribute("DataLoaded", true)
	
	-- Custom Spawning System (Bypasses Roblox's native spawn issues)
	local function HandleSpawning(Character)
		-- Give a brief moment for native spawning to settle
		task.wait(0.1)
		if not Character.Parent or not Character:FindFirstChild("HumanoidRootPart") then return end

		local pDataFolder = PlayerData:FindFirstChild(Player.UserId)
		if not pDataFolder then return end

		local Level = pDataFolder.Stats.Level.Value
		local TargetSpawn = nil

		-- Make sure to find your spawns correctly
		local TutorialSpawn = workspace:FindFirstChild("TutorialSpawnLocation", true)

		-- 1. Check for a saved custom RespawnStone FIRST
		local savedRespawnName = Player:GetAttribute("RespawnPoint")
		if savedRespawnName then
			for _, stone in ipairs(CollectionService:GetTagged("RespawnStone")) do
				if stone.Name == savedRespawnName then
					-- Finds the SpawnLocation, or falls back to any part of the stone
					TargetSpawn = stone:FindFirstChildWhichIsA("SpawnLocation", true) or stone
					break
				end
			end
		end

		-- 2. If no valid respawn stone was found, THEN check if they should go to Tutorial
		if not TargetSpawn and Level < 2 and TutorialSpawn then
			TargetSpawn = TutorialSpawn
		end

		-- Teleport the player manually to their respawn point or tutorial
		if TargetSpawn == TutorialSpawn then
			Character:PivotTo(TargetSpawn.CFrame + Vector3.new(0, 0.5, 0))
		elseif TargetSpawn then
			Character:PivotTo(TargetSpawn.CFrame + Vector3.new(0, 0.5, 0))
		else
			-- Default to tutorial spawn if no respawn point is set (and tutorial spawn exists)
			if TutorialSpawn then
				Character:PivotTo(TutorialSpawn.CFrame + Vector3.new(0, 0.5, 0))
			end
		end
	end

	-- Connect so this fires every time the player dies & respawns
	Player.CharacterAdded:Connect(HandleSpawning)

	-- Fire it immediately for their first spawn
	if Player.Character then
		task.spawn(HandleSpawning, Player.Character)
	end
end

Players.PlayerAdded:Connect(OnPlayerAdded)
for _, Player in Players:GetPlayers() do OnPlayerAdded(Player) end

Players.PlayerRemoving:Connect(function(Player)
	SaveData(Player)
	local oldData = PlayerData:FindFirstChild(Player.UserId)
	if oldData then oldData:Destroy() end
end)

game:BindToClose(function()
	if RunService:IsStudio() then task.wait(1) return end
	for _, Player in Players:GetPlayers() do SaveData(Player) end
	task.wait(1)
end)

EventModule:GetOnServerEvent("OpenLevelDoor"):Connect(function(Player, DoorName)
	local pDataFolder = PlayerData:FindFirstChild(Player.UserId)
	if pDataFolder then
		local OpenedDoorsFolder = pDataFolder:FindFirstChild("OpenedDoors")
		if OpenedDoorsFolder and not OpenedDoorsFolder:FindFirstChild(DoorName) then
			local Value = Instance.new("BoolValue")
			Value.Name = DoorName
			Value.Value = true
			Value.Parent = OpenedDoorsFolder
		end
	end
end)

while task.wait(GameConfig.SaveTime) do
	for _, Player in Players:GetPlayers() do task.spawn(SaveData, Player) end
end

return {}
