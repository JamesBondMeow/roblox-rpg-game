--[[
	giveItemWithAmount
	
	Simple utility to change add/remove based off of an amount
]]

--> Services
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local ServerStorage = game:GetService("ServerStorage")
local Players = game:GetService("Players")

--> Player
local PlayerData = ReplicatedStorage:WaitForChild("PlayerData")

--> Dependencies
local ContentLibrary = require(ReplicatedStorage.Modules.Shared.ContentLibrary)

--> Variables
local Libraries = {}
for _, Module in ServerStorage.Modules.Libraries["items [Subcategories]"]:GetChildren() do
	Libraries[Module.Name] = require(Module)
end

--------------------------------------------------------------------------------

return function(Player, ItemType: string, CompoundItemName: string, Amount)
	local pData = PlayerData:FindFirstChild(Player.UserId)
	if not pData then return end

	-- Parse the compound name to safely get the ContentLibrary data
	local split = string.split(tostring(CompoundItemName), "|")
	local baseName = split[1]

	local OriginalItem = ContentLibrary[ItemType] and ContentLibrary[ItemType][baseName]
	if not OriginalItem then return end

	-- Create a Proxy table! This forces the native Give function to use the enchanted name, 
	-- while safely falling back to OriginalItem for everything else (like Instance and Config).
	local Item = setmetatable({
		Name = CompoundItemName
	}, {__index = OriginalItem})

	local IsNumberValue = Item.Instance.ClassName == "NumberValue"
	if IsNumberValue then
		Libraries[ItemType]:Give(Player, Item, nil, "Force", Amount)
	elseif not IsNumberValue then
		for Iteration = 1, Amount or 1 do
			Libraries[ItemType]:Give(Player, Item, nil, "Force")
		end
	end
end
