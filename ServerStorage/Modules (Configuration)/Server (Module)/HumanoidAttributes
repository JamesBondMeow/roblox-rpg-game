--[[
	HumanoidAttributes
	
	One important thing about this kit, is that you should never set a player's MaxHealth,
	WalkSpeed, and JumpPower manually through Humanoid properties.
	
	The kit uses a feature known as Humanoid "Attributes", which is a Configuration under the Humanoid
	(Humanoid.Attributes). Under here is another Configuration for each value.
	
	These Configurations have Attributes (shown at the bottom of the Properties window) which can be added
	to increase the total health.
	
	The reason this is done is so that we can add other sources of health (Game passes, Armor, etc), and the game
	won't lose track, or be forced to set the health to (100 + n).
	
	----------------------------------------------------------------------------
	
	It may sound confusing, but essentially, you can add 250 health to the character by doing this:
	> Character.Humanoid.Attributes.Health:SetAttribute("Premium VIP", 250)
	
	There are now two sources of Health
	• "Default": 100
	• "Premium VIP": 250
	
	The total is automatically calculated (250+100 = 350), and set as the player's new MaxHealth for the character.
	
	You can remove health by setting an attribute to nil
	> Character.Humanoid.Attributes.Health:SetAttribute("Premium VIP", nil)
	
	• "Default": 100
	
	The total is automatically calculated (100 = 100), and set as the player's new MaxHealth for the character.
	
	This can be done with other values as well. There are currently only three supported values:
	• Health (MaxHealth),
	• WalkSpeed,
	• JumpPower
]]

--> Services
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local ContentLibrary = require(ReplicatedStorage:WaitForChild("Modules"):WaitForChild("Shared"):WaitForChild("ContentLibrary"))
local Players = game:GetService("Players")

--> Dependencies
local GameConfig = require(ReplicatedStorage.GameConfig)

local RegenerationModifiers = {}
for _, Module in script.HealthRegen:GetChildren() do
	RegenerationModifiers[Module.Name] = require(Module)
end

--> Variables
local HumanoidAttributes = {}
HumanoidAttributes.__index = HumanoidAttributes

local DefaultValues = GameConfig.DefaultHumanoid
local RegenerateRate = GameConfig.Regenerate.Rate
local RegenerateStep = GameConfig.Regenerate.Step

export type HumanoidAttributes = {
	Instance: Configuration,
	Humanoid: Humanoid,
	Update: (self: HumanoidAttributes) -> ()
}

local function GetToolEnchantmentProps(Tool, TargetFamily)
	if not Tool then return nil end
	local enchantAttr = Tool:GetAttribute("Enchantments")
	if not enchantAttr or enchantAttr == "" then return nil end

	local enchants = string.split(enchantAttr, ",")
	for _, enchantId in ipairs(enchants) do
		local config = ContentLibrary.Material[enchantId]
		if not config then
			for _, matData in pairs(ContentLibrary.Material) do
				if matData.Config and matData.Config.EnchantmentData and matData.Config.EnchantmentData.Id == enchantId then
					config = matData
					break
				end
			end
		end
		if config and config.Config.EnchantmentData then
			local family = config.Config.EnchantmentData.Family or string.split(enchantId, "_")[1]
			if family == TargetFamily then
				return config.Config.EnchantmentData.Properties or {}
			end
		end
	end
	return nil
end

local function GetArmorEnchantmentProps(Player, TargetFamily)
	local pData = ReplicatedStorage:WaitForChild("PlayerData"):FindFirstChild(Player.UserId)
	local ActiveArmor = pData and pData:FindFirstChild("ActiveArmor")
	if not ActiveArmor then return nil, 0 end

	local combinedProps = nil
	local stacks = 0

	for _, slot in ipairs({"Helmet", "Pauldron", "Chestplate"}) do
		local armorStr = ActiveArmor[slot].Value
		if armorStr ~= "" and string.find(armorStr, "|") then
			local split = string.split(armorStr, "|")
			for i = 2, #split do
				local enchantId = split[i]
				local config = ContentLibrary.Material[enchantId]
				if not config then
					for _, matData in pairs(ContentLibrary.Material) do
						if matData.Config and matData.Config.EnchantmentData and matData.Config.EnchantmentData.Id == enchantId then
							config = matData
							break
						end
					end
				end

				if config and config.Config.EnchantmentData then
					local family = config.Config.EnchantmentData.Family or string.split(enchantId, "_")[1]
					if family == TargetFamily then
						combinedProps = combinedProps or config.Config.EnchantmentData.Properties or {}
						stacks += 1
					end
				end
			end
		end
	end
	return combinedProps, stacks
end

----------------------------------------------------------------------------

function HumanoidAttributes.new(Humanoid: Humanoid): HumanoidAttributes
	local self = setmetatable({}, HumanoidAttributes) -- Looks complex, but all this does here is redirect an index to under HumanoidAttributes table if it doesn't exist in self.
	
	local Character = Humanoid.Parent
	self.Character = Character
	
	local Player = Players:GetPlayerFromCharacter(Character)
	self.Player = Player
	
	local Configuration = Instance.new("Configuration")
	Configuration.Name = "Attributes"
	
	for Name, DefaultValue in DefaultValues do
		local SubConfig = Instance.new("Configuration")
		SubConfig.Name = Name
		SubConfig.Parent = Configuration
		SubConfig:SetAttribute("Default", DefaultValue)
		
		SubConfig.AttributeChanged:Connect(function(AttributeName)
			self:Update()
		end)
	end
	
	Configuration.Parent = Humanoid
	
	self.Instance = Configuration
	self.Humanoid = Humanoid

	Humanoid.UseJumpPower = true

	-- Listeners for Tool Curses (David & Parasite)
	local Character = Humanoid.Parent
	if Character then
		Character.ChildAdded:Connect(function(child)
			if child:IsA("Tool") then
				self:Update()
				-- Clamp health immediately when equipping David
				task.defer(function()
					if self.Humanoid and self.Humanoid.Health > self.Humanoid.MaxHealth then
						self.Humanoid.Health = self.Humanoid.MaxHealth
					end
				end)
			end
		end)
		Character.ChildRemoved:Connect(function(child)
			if child:IsA("Tool") then
				self:Update()
			end
		end)
	end

	self:Update()
	self:StepRegenerate()
	return self
end

function HumanoidAttributes:Update()
	for _, SubConfig in self.Instance:GetChildren() do
		if SubConfig:IsA("Configuration") then
			local n = 0
			for Name, Value in SubConfig:GetAttributes() do
				if typeof(Value) == "number" then
					n += Value
				end
			end

			if SubConfig.Name == "Health" and self.Humanoid.Parent then
				local multiplier = 1

				-- Apply Armor Modifiers Natively (Vitality & Goliath)
				if self.Player then
					local vitalityProps, vitalityStacks = GetArmorEnchantmentProps(self.Player, "Vitality")
					if vitalityStacks > 0 then
						multiplier += ((vitalityProps and vitalityProps.HealthIncrease or 0.10) * vitalityStacks)
					end

					local goliathProps, goliathStacks = GetArmorEnchantmentProps(self.Player, "Goliath")
					if goliathStacks > 0 then
						multiplier += ((goliathProps and goliathProps.HealthMultiplier or 0.50) * goliathStacks)
					end
				end

				-- Apply multipliers to the total health pool
				n = math.round(n * multiplier)

				-- Apply David MaxHealth Cap natively on the Server (Applies last to halve the final pool)
				local Tool = self.Humanoid.Parent:FindFirstChildWhichIsA("Tool")
				local davidProps = GetToolEnchantmentProps(Tool, "David")
				if davidProps then
					n = math.round(n * (davidProps.HealthCap or 0.5))
				end
			end

			local PropertyName = (SubConfig.Name == "Health" and "MaxHealth") or SubConfig.Name
			local Percent = SubConfig.Name == "Health" and (self.Humanoid.Health/self.Humanoid.MaxHealth)

			self.Humanoid[PropertyName] = n

			-- Force health to instantly clamp if Maximum Health shrinks below Current Health
			if SubConfig.Name == "Health" then
				if Percent == 1 and GameConfig.HumanoidStatsRefreshWhenAdded then
					self.Humanoid.Health = self.Humanoid.MaxHealth
				end

				task.defer(function()
					if self.Humanoid and self.Humanoid.Health > self.Humanoid.MaxHealth then
						self.Humanoid.Health = self.Humanoid.MaxHealth
					end
				end)
			end
		end
	end
end

function HumanoidAttributes:StepRegenerate()
	task.spawn(function()
		local parasiteTimer = 0

		while self and self.Humanoid.Parent ~= nil do
			local DeltaTime = task.wait(RegenerateStep)

			-- 1. Standard Regeneration (Always active, allowing players to out-heal the curse)
			if self.Humanoid.Health < self.Humanoid.MaxHealth then
				local DeltaHealth = DeltaTime * RegenerateRate * self.Humanoid.MaxHealth
				self.Humanoid.Health = math.clamp(self.Humanoid.Health + DeltaHealth, 0, self.Humanoid.MaxHealth)
			end

			-- 2. Parasite Drain (Only drains once per second)
			local Tool = self.Humanoid.Parent:FindFirstChildWhichIsA("Tool")
			local parasiteProps = GetToolEnchantmentProps(Tool, "Parasite")

			if parasiteProps then
				parasiteTimer += DeltaTime

				if parasiteTimer >= 1 then
					parasiteTimer -= 1 -- Keep perfect 1-second timing

					if self.Humanoid.Health > 1 then
						local drain = self.Humanoid.MaxHealth * (parasiteProps.HealthDrain or 0.01)
						self.Humanoid.Health = math.max(1, self.Humanoid.Health - drain)
					end
				end
			else
				-- Reset the timer if the weapon is unequipped
				parasiteTimer = 0 
			end
		end
	end)
end

return HumanoidAttributes
