--[[
	removeItemWithAmount
	
	Simple utility to change add/remove based off of an amount
]]

--> Services
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local ServerStorage = game:GetService("ServerStorage")
local Players = game:GetService("Players")

--> Player
local PlayerData = ReplicatedStorage:WaitForChild("PlayerData")

--> Dependencies
local ContentLibrary = require(ReplicatedStorage.Modules.Shared.ContentLibrary)

--> Variables
local Libraries = {}
for _, Module in ServerStorage.Modules.Libraries["items [Subcategories]"]:GetChildren() do
	Libraries[Module.Name] = require(Module)
end

--------------------------------------------------------------------------------

return function(Player, ItemType: string, CompoundItemName: string, Amount: number)
	local pData = PlayerData:FindFirstChild(Player.UserId)
	if not pData then return end

	-- Parse the compound name so we can read the base configuration
	local split = string.split(tostring(CompoundItemName), "|")
	local baseName = split[1]

	local enchants = {}
	for i = 2, #split do table.insert(enchants, split[i]) end
	local targetEnchantAttr = #enchants > 0 and table.concat(enchants, ",") or nil

	local Item = ContentLibrary[ItemType] and ContentLibrary[ItemType][baseName]
	if not Item then return end

	local IsNumberValue = Item.Instance.ClassName == "NumberValue"

	-- If it's a pure NumberValue (like Materials) with no enchantments, let the native library handle it safely
	if IsNumberValue and #enchants == 0 then
		Libraries[ItemType]:Trash(Player, Item, Amount)
		return
	end

	-- Otherwise, we must manually delete the exact enchanted variant

	-- 1. Deduct from PlayerData
	local itemFolder = pData:FindFirstChild("Items") and pData.Items:FindFirstChild(ItemType)
	local valueObj = itemFolder and itemFolder:FindFirstChild(CompoundItemName)

	if valueObj then
		valueObj.Value -= Amount
		if valueObj.Value <= 0 then
			valueObj:Destroy()
		end
	end

	-- 2. Physically remove the Tool/Armor
	if not IsNumberValue then
		local character = Player.Character
		local backpack = Player:FindFirstChild("Backpack")
		local starterGear = Player:FindFirstChild("StarterGear")

		local removedCount = 0

		local function removePhysical(container)
			if not container then return end
			for _, tool in ipairs(container:GetChildren()) do
				if removedCount >= Amount then break end

				-- We must match BOTH the base name and the exact enchantments
				if tool.Name == baseName then
					local currentEnchantAttr = tool:GetAttribute("Enchantments")
					if currentEnchantAttr == "" then currentEnchantAttr = nil end

					if currentEnchantAttr == targetEnchantAttr then
						tool:Destroy()
						removedCount += 1
					end
				end
			end
		end

		removePhysical(character)
		removePhysical(backpack)

		removedCount = 0 -- Reset for StarterGear so it removes the exact amount from there too
		removePhysical(starterGear)
	end
end
