--[[
    ClientOrbAnimator (local script)
    
    This script runs on the client and handles the visual orbiting animation
    for all players' equipped orbs. It now also handles animating an orb
    moving to attack a target when instructed by the server.
]]

-- Services
local RunService = game:GetService("RunService")
local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local TweenService = game:GetService("TweenService")

-- Dependencies
local EventModule = require(ReplicatedStorage.Modules.Shared.Event)

-- Configuration
local ORB_RADIUS = 10
local ORBIT_SPEED = 100 -- Degrees per second

-- A table to store the animation state for each character.
local characterOrbSystems = {}

-- This function sets up a new orb system for a character or finds the existing one.
local function getOrCreateCharSystem(character)
	if not characterOrbSystems[character] then
		characterOrbSystems[character] = {
			baseAngle = 0,
			orbs = {} -- Will store individual orb data
		}
		character.Destroying:Connect(function()
			characterOrbSystems[character] = nil
		end)
	end
	return characterOrbSystems[character]
end

-- Listen for the server's command to animate an orb attack
EventModule:GetOnClientEvent("AnimateOrbAttack"):Connect(function(player, orbIndex, target)
	if not player or not player.Character or not target then return end

	local system = getOrCreateCharSystem(player.Character)
	local orbData = system.orbs[tostring(orbIndex)]

	if orbData and orbData.part then
		-- Tell this orb to override its orbit and move to the target
		orbData.overrideTarget = target
	end
end)

-- Listen for the server's command to return to orbit
EventModule:GetOnClientEvent("AnimateOrbReturn"):Connect(function(player, orbIndex)
	if not player or not player.Character then return end

	local system = getOrCreateCharSystem(player.Character)
	local orbData = system.orbs[tostring(orbIndex)]

	if orbData then
		-- Clear the override target, allowing the orb to return to its orbit
		orbData.overrideTarget = nil
	end
end)


-- The main animation loop, runs on every frame
RunService.RenderStepped:Connect(function(deltaTime)
	-- Loop through all the character systems we're tracking
	for character, system in pairs(characterOrbSystems) do
		local rootPart = character and character:FindFirstChild("HumanoidRootPart")
		if not rootPart then continue end

		local orbGroup = character:FindFirstChild("OrbGroup")

		-- Sync the client's orb list with the character's OrbGroup
		if orbGroup then
			-- Add new orbs
			for _, orbPart in ipairs(orbGroup:GetChildren()) do
				if not system.orbs[orbPart.Name] then
					system.orbs[orbPart.Name] = { part = orbPart, overrideTarget = nil }
				end
			end
			-- Remove old orbs
			for index, orbData in pairs(system.orbs) do
				if not orbGroup:FindFirstChild(index) then
					system.orbs[index] = nil
				end
			end
		elseif next(system.orbs) then -- Check if table is not empty before clearing
			-- Clear all orbs if the group is gone
			system.orbs = {}
		end

		if not next(system.orbs) then continue end

		-- Increment the SHARED base angle for the entire group
		local rotationIncrement = math.rad(ORBIT_SPEED) * deltaTime
		system.baseAngle = (system.baseAngle + rotationIncrement) % (2 * math.pi)

		-- This ensures the orbit plane is always level with the ground
		local anchorCFrame = CFrame.new(rootPart.Position)

		-- Create a sorted list of orbs to ensure stable positioning
		local sortedOrbs = {}
		for _, orbData in pairs(system.orbs) do
			table.insert(sortedOrbs, orbData.part)
		end
		table.sort(sortedOrbs, function(a, b) return a.Name < b.Name end)

		local angleIncrement = (2 * math.pi) / #sortedOrbs

		for i, orbPart in ipairs(sortedOrbs) do
			local orbData = system.orbs[orbPart.Name]
			local weld = orbPart:FindFirstChild("OrbWeld")
			if not weld then continue end

			local targetCFrame
			if orbData.overrideTarget and orbData.overrideTarget.Parent then
				-- ATTACKING: The target is the overridden mob
				local targetRoot = orbData.overrideTarget:FindFirstChild("HumanoidRootPart")
				if targetRoot then
					targetCFrame = CFrame.new(targetRoot.Position)
				else
					-- If the target is invalid (e.g., no HumanoidRootPart), stop targeting it.
					orbData.overrideTarget = nil
				end
			end

			-- If targetCFrame is still nil, it means we are orbiting
			if not targetCFrame then
				-- ORBITING: Calculate the orbit position
				local angleOffset = (i - 1) * angleIncrement
				local finalAngle = system.baseAngle + angleOffset

				local orbitalOffset = CFrame.new(
					ORB_RADIUS * math.cos(finalAngle),
					0,
					ORB_RADIUS * math.sin(finalAngle)
				)
				targetCFrame = anchorCFrame * orbitalOffset
			end

			-- Smoothly move the weld toward the target CFrame
			local goalCFrame = rootPart.CFrame:ToObjectSpace(targetCFrame)
			weld.C1 = weld.C1:Lerp(goalCFrame, 0.1)
		end
	end
end)

-- Initial setup for all players
Players.PlayerAdded:Connect(function(player)
	player.CharacterAdded:Connect(getOrCreateCharSystem)
	if player.Character then
		getOrCreateCharSystem(player.Character)
	end
end)
for _, player in ipairs(Players:GetPlayers()) do
	player.CharacterAdded:Connect(getOrCreateCharSystem)
	if player.Character then
		getOrCreateCharSystem(player.Character)
	end
end
