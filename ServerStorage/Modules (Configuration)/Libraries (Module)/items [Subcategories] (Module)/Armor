local ArmorContent = {}
local function AddArmorToContent(ArmorInstance)
	local Config = require(ArmorInstance:FindFirstChildWhichIsA("ModuleScript"))
	if ArmorContent[Config.Name] then return end
	ArmorContent[Config.Name] = Config
end

for _, ArmorInstance in CollectionService:GetTagged("Armor") do
	task.spawn(AddArmorToContent, ArmorInstance)
end
CollectionService:GetInstanceAddedSignal("Armor"):Connect(AddArmorToContent)

-- Remotes
local function RequestUnequipArmor(Player, ArmorName)
	local pData = PlayerData:WaitForChild(Player.UserId)
	local ActiveArmor = pData.ActiveArmor
	local TargetSlot = nil

	if ArmorName then
		for _, Slot in ActiveArmor:GetChildren() do
			if Slot.Value == ArmorName then
				TargetSlot = Slot
				break
			end
		end
	else
		return
	end

	if TargetSlot then
		ArmorLib:UnequipArmor(Player, TargetSlot.Value, TargetSlot.Name)
	end
end

local function RequestEquipArmor(Player, ArmorName)
	local pData = PlayerData:WaitForChild(Player.UserId)

	-- Parse compound string natively
	local baseName = ParseCompoundName(ArmorName)
	local Item = ContentLibrary.Armor[baseName]

	if Item and pData.Items.Armor:FindFirstChild(ArmorName) then
		ArmorLib:EquipArmor(Player, Item, ArmorName)
		return true
	end
	return false
end

EventModule:GetOnServerInvoke("EquipArmor", RequestEquipArmor)
EventModule:GetOnServerInvoke("UnequipArmor", RequestUnequipArmor)

--------------------------------------------------------------------------------

local function OnPlayerAdded(Player: Player)
	local pData = PlayerData:WaitForChild(Player.UserId)

	local function OnCharacterAdded(Character)
		local ActiveArmorFolder = pData:WaitForChild("ActiveArmor")

		local Connection = Character.ChildAdded:Connect(function(Child)
			if Child:IsA("Accessory") then
				Morph:UpdateAccessoriesTransparency(Character, nil) 
			end
		end)
		Player.CharacterRemoving:Once(function() Connection:Disconnect() end)

		for _, Slot in ActiveArmorFolder:GetChildren() do
			if Slot.Value ~= "" then
				local baseName = ParseCompoundName(Slot.Value)
				local Armor = ContentLibrary.Armor[baseName]
				if Armor then
					if Player:HasAppearanceLoaded() then
						ArmorLib:EquipArmor(Player, Armor, Slot.Value)
					else
						Player.CharacterAppearanceLoaded:Once(function()
							ArmorLib:EquipArmor(Player, Armor, Slot.Value)
						end)
					end
				end
			end
		end
	end

	Player.CharacterAdded:Connect(OnCharacterAdded)
	if Player.Character then OnCharacterAdded(Player.Character) end
end

Players.PlayerAdded:Connect(OnPlayerAdded)
for _, Player in Players:GetPlayers() do task.spawn(OnPlayerAdded, Player) end

return ArmorLib
