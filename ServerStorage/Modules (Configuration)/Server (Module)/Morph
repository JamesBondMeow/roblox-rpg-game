-- Armor

-- Updates transparency of body parts based on ALL equipped armor pieces
function Morph:UpdateLimbTransparency(Character: Model, ArmorGroup: Folder)
	local PartsToHide = {}

	-- Gather all parts that should be hidden by ANY equipped armor
	for _, ArmorModel in ArmorGroup:GetChildren() do
		-- Assuming we attached the config to the model or we look it up?
		-- Better: We rely on the Armor Config passed during Apply, but for full update we need to check active models.
		-- Strategy: We assume the ArmorModel in ArmorGroup has attributes or we re-check transparency every Equip.
		-- Actually, simplest way: Reset all to visible, then loop through Active Armor (passed or derived).
	end

	-- NOTE: ArmorLib calls ApplyOutfit. To correctly handle transparency stacking (e.g. Helmet hides head, Chestplate hides Chest),
	-- we really need the Configs of all active armors.
	-- For now, we will handle transparency individually per piece in `ApplyOutfit` by checking `ArmorConfig.BodyPartsVisible`.
	-- However, to be robust, if Armor A hides Head, and Armor B shows Head, Head should be HIDDEN.

	-- Reset Character Transparency first
	for _, Instance in Character:GetChildren() do
		if Instance:IsA("BasePart") then
			local Original = Instance:GetAttribute("OriginalTransparency")
			if Original then Instance.Transparency = Original end
		end
	end

	-- Apply Hiding
	-- We iterate through the ArmorGroup models. 
	-- NOTE: This requires the ArmorModel to have the Config info or we pass all active armor configs to this function.
	-- To keep it simple, we will assume `Armor.Config` is accessible.
end

-- Helper to weld
local function WeldArmorLimb(ArmorLimb: Model, BodyLimb: BasePart)
	local Middle = ArmorLimb:FindFirstChild("Middle")

	for _, Piece: Instance in ArmorLimb:GetDescendants() do
		if Piece:IsA("BasePart") then
			Piece.Anchored = false
			Piece.CanCollide = false
			Piece.CanQuery = false
			Piece.Massless = true
			if Piece.Name ~= "Middle" then
				local Weld = Instance.new("Weld")
				Weld.Name = Piece.Name .."/".. Middle.Name
				Weld.Part0 = Middle
				Weld.Part1 = Piece
				Weld.C1 = Piece.CFrame:Inverse() * Middle.CFrame
				Weld.Parent = Middle
			end
		end
	end

	local Weld = Instance.new("Weld")
	Weld.Name = BodyLimb.Name .."/".. Middle.Name
	Weld.Part0 = BodyLimb
	Weld.Part1 = Middle
	Weld.Parent = Middle
end

function Morph:CreatePhysicalModel(Player: Player, Object, Group)
	local Character = if Player:IsA("Model") then Player else Player.Character
	if not Character then return end

	for _, Limb in Object.Instance:GetChildren() do
		if not Limb:IsA("Model") then
			Limb:Clone().Parent = Group
			continue
		end

		Limb = Limb:Clone()
		local Middle = Limb:FindFirstChild("Middle")
		local BodyLimb = Character:FindFirstChild(Limb.Name)

		if Middle and BodyLimb then
			WeldArmorLimb(Limb, BodyLimb)
			Limb.Parent = Group
		elseif not Middle then
			warn(("Model limb %s/%s is missing a \"Middle\" BasePart!"):format(Object.Name, Limb.Name))
		end
	end
	return Group
end

-- Main Function to Apply a specific piece of armor
function Morph:ApplyOutfit(Player: Player, Armor, ActiveArmorTable)
	local Character = if Player:IsA("Model") then Player else Player.Character
	if not Character then return end

	local ArmorGroup = Character:FindFirstChild("ArmorGroup")
	if not ArmorGroup then
		ArmorGroup = Instance.new("Folder")
		ArmorGroup.Name = "ArmorGroup"
		ArmorGroup.Parent = Character
	end

	local ArmorType = Armor.Config.ArmorType or "Chestplate"

	-- 1. Remove existing model of this type
	local Existing = ArmorGroup:FindFirstChild(ArmorType)
	if Existing then Existing:Destroy() end

	-- 2. Create new Model for this type
	local TypeGroup = Instance.new("Model")
	TypeGroup.Name = ArmorType
	self:CreatePhysicalModel(Player, Armor, TypeGroup)
	TypeGroup.Parent = ArmorGroup

	-- 3. Handle Clothing (Only for Chestplate usually)
	if ArmorType == "Chestplate" then
		for _, ClassName in {"Shirt", "Pants"} do
			local ClothingID = ClothingLibrary[Armor.Name] and ClothingLibrary[Armor.Name][ClassName]
			local _Clothing = Character:FindFirstChildWhichIsA(ClassName)

			-- Logic to save original ID and apply new one
			if _Clothing then
				if not _Clothing:GetAttribute("OriginalID") then
					_Clothing:SetAttribute("OriginalID", _Clothing[ClassName.."Template"])
				end
			end

			if ClothingID then
				if not _Clothing then
					_Clothing = Instance.new(ClassName)
					_Clothing.Parent = Character
				end
				_Clothing[ClassName.."Template"] = ClothingID
			elseif _Clothing and _Clothing:GetAttribute("OriginalID") then
				-- Restore if chestplate has no clothing
				_Clothing[ClassName.."Template"] = _Clothing:GetAttribute("OriginalID")
			end
		end
	end

	-- 4. Handle Limb Transparency (Iterate ALL active armor configs provided)
	-- Initialize transparency reset
	for _, Instance in Character:GetChildren() do
		if Instance:IsA("BasePart") then
			if not Instance:GetAttribute("OriginalTransparency") then
				Instance:SetAttribute("OriginalTransparency", Instance.Transparency)
			end
			Instance.Transparency = Instance:GetAttribute("OriginalTransparency") or 0
		end
	end

	-- Apply hiding from all active pieces
	if ActiveArmorTable then
		for _, ActiveArmorObj in pairs(ActiveArmorTable) do
			if ActiveArmorObj and ActiveArmorObj.Config.BodyPartsVisible then
				for PartName, IsVisible in pairs(ActiveArmorObj.Config.BodyPartsVisible) do
					if IsVisible == false then -- If config says HIDDEN (false)
						local BodyPart = Character:FindFirstChild(PartName)
						if BodyPart and BodyPart:IsA("BasePart") then
							BodyPart.Transparency = 1
						end
					end
				end
			end
		end
	end

	self:UpdateAccessoriesTransparency(Character, Armor) -- Legacy accessory hider
end

function Morph:ClearOutfit(Player: Player, ArmorType: string, ActiveArmorTable)
	local Character = if Player:IsA("Model") then Player else Player.Character
	if not Character then return end

	local ArmorGroup = Character:FindFirstChild("ArmorGroup")
	if ArmorGroup then
		local Target = ArmorGroup:FindFirstChild(ArmorType)
		if Target then Target:Destroy() end
	end

	-- Revert clothing if chestplate removed
	if ArmorType == "Chestplate" then
		for _, ClassName in {"Shirt", "Pants"} do
			local Clothing = Character:FindFirstChildWhichIsA(ClassName)
			if Clothing then
				local OriginalID = Clothing:GetAttribute("OriginalID")
				if OriginalID then
					Clothing[ClassName.."Template"] = OriginalID
				end
			end
		end
	end

	-- Recalculate transparency based on REMAINING armor in ActiveArmorTable
	for _, Instance in Character:GetChildren() do
		if Instance:IsA("BasePart") then
			local Original = Instance:GetAttribute("OriginalTransparency")
			if Original then Instance.Transparency = Original end
		end
	end

	if ActiveArmorTable then
		for Type, ActiveArmorObj in pairs(ActiveArmorTable) do
			if Type ~= ArmorType and ActiveArmorObj and ActiveArmorObj.Config.BodyPartsVisible then
				for PartName, IsVisible in pairs(ActiveArmorObj.Config.BodyPartsVisible) do
					if IsVisible == false then
						local BodyPart = Character:FindFirstChild(PartName)
						if BodyPart then BodyPart.Transparency = 1 end
					end
				end
			end
		end
	end
end

